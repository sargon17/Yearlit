    "Track your year's progress with a beautiful visualization.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni traccia del progresso del tuo anno con una bella visualizzazione."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відстежуйте прогрес року за допомогою красивої візуалізації."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Realice un seguimiento del progreso de su año con una hermosa visualización."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Realice un seguimiento del progreso de su año con una hermosa visualización."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acompanhe o progresso do seu ano com uma bela visualização."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolgen Sie den Fortschritt Ihres Jahres mit einer schönen Visualisierung."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez les progrès de votre année avec une belle visualisation."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Volg de voortgang van uw jaar met een prachtige visualisatie."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Følg dit års fremskridt med en smuk visualisering."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spåra ditt års framsteg med en vacker visualisering."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Følg årets fremgang med en vakker visualisering."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Śledź postępy w ciągu roku dzięki pięknej wizualizacji."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Seuraa vuoden edistymistä kauniilla visualisoinneilla."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledujte pokrok svého roku pomocí krásné vizualizace."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Urmăriți progresul anului dvs. cu o vizualizare frumoasă."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kövesse nyomon az év előrehaladását egy gyönyörű vizualizációval."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledujte pokrok svojho roka pomocou krásnej vizualizácie."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pratite napredak svoje godine uz prekrasnu vizualizaciju."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spremljajte napredek v letu s čudovito vizualizacijo."
          }
        },
        "et": {
