        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koppints egy naptárra az archiválás megszüntetéséhez, és visszakerül a tábláidra."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca un calendario per dearchiviarlo e riportarlo nei tuoi board."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pieskaries kalendāram, lai to atarhivētu un atgrieztu dēļos."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
