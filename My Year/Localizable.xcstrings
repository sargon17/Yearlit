    "Archiving hides this calendar from your boards without deleting past data." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archivace skryje tento kalendář z vašich nástěnek, aniž by došlo ke smazání minulých dat."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arkivering skjuler denne kalender fra dine tavler uden at slette tidligere data."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archivieren blendet diesen Kalender auf deinen Boards aus, ohne frühere Daten zu löschen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archiving hides this calendar from your boards without deleting past data."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archivar oculta este calendario de tus tableros sin eliminar datos anteriores."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archivar oculta este calendario de tus tableros sin eliminar datos anteriores."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arhiveerimine peidab selle kalendri sinu tahvlitelt, kustutamata varasemaid andmeid."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arkistointi piilottaa tämän kalenterin tauluiltasi poistamatta aiempia tietoja."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'archivage masque ce calendrier de vos tableaux sans supprimer les données passées."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arhiviranje skriva ovaj kalendar s tvojih ploča bez brisanja prošlih podataka."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az archiválás elrejti ezt a naptárt a táblákról a korábbi adatok törlése nélkül."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'archiviazione nasconde questo calendario dalle tue bacheche senza eliminare i dati passati."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arhivēšana paslēpj šo kalendāru no taviem dēļiem, neizdzēšot iepriekšējos datus."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arkivering skjuler denne kalenderen fra tavlene dine uten å slette tidligere data."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archiveren verbergt deze kalender op je borden zonder eerdere data te verwijderen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archiwizacja ukrywa ten kalendarz przed Twoimi tablicami bez usuwania wcześniejszych danych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arquivar oculta este calendário dos seus quadros sem apagar dados antigos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arhivarea ascunde calendarul din panouri fără să șteargă datele vechi."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archivácia skryje tento kalendár z násteniek, ale minulé údaje nezmaže."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arhiviranje skrije ta koledar s tvojih pregledov, ne izbriše pa preteklih podatkov."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arkivering döljer kalendern från dina vyer utan att radera historiken."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Архівування приховує цей календар із ваших дошок, не видаляючи минулі дані."
          }
        }
      }
    },
    "Are you sure you want to delete '\\(calendar.name)'? This action cannot be undone." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opravdu chcete smazat „\\(calendar.name)“? Tuto akci nelze vrátit zpět."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på, at du vil slette '\\(calendar.name)'? Denne handling kan ikke fortrydes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Möchtest du „\\(calendar.name)“ wirklich löschen? Das kann nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea eliminar '\\(calendar.name)'? Esta acción no se puede deshacer."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea eliminar '\\(calendar.name)'? Esta acción no se puede deshacer."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kas olete kindel, et soovite \"\\(calendar.name)\" kustutada? Seda toimingut ei saa tagasi võtta."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haluatko varmasti poistaa kohteen\\(calendar.name)? Tätä toimintoa ei voi kumota."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Etes-vous sûr de vouloir supprimer «\\(calendar.name)»? Cette action ne peut pas être annulée."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeste li sigurni da želite izbrisati '\\(calendar.name)'? Ova se radnja ne može poništiti."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biztosan törli a következőt: \"\\(calendar.name)\"? Ez a művelet nem vonható vissza."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vuoi eliminare \"\\(calendar.name)\"? Questa azione non può essere annullata."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vai tiešām dzēst “\\(calendar.name)”? Šo darbību nevar atsaukt."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er du sikker på at du vil slette '\\(calendar.name)'? Denne handlingen kan ikke angres."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weet je zeker dat je '\\(calendar.name)' wilt verwijderen? Dit kun je niet ongedaan maken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Czy na pewno chcesz usunąć „\\(calendar.name)”? Tej akcji nie można cofnąć."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tem certeza de que quer excluir '\\(calendar.name)'? Essa ação não pode ser desfeita."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sigur vrei să ștergi „\\(calendar.name)”? Acțiunea nu poate fi anulată."
