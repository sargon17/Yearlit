    "We will send you a reminder when you're about to miss a day." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Když zmeškáte některý den, zašleme vám připomenutí."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi sender dig en påmindelse, når du er ved at gå glip af en dag."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir erinnern dich, wenn du kurz davor bist, einen Tag zu verpassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We will send you a reminder when you're about to miss a day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le enviaremos un recordatorio cuando esté a punto de perderse un día."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le enviaremos un recordatorio cuando esté a punto de perderse un día."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Saadame teile meeldetuletuse, kui teil jääb mõni päev vahele."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lähetämme sinulle muistutuksen, kun jokin päivä jää väliin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous vous enverrons un rappel lorsque vous êtes sur le point de manquer une journée."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poslat ćemo ti podsjetnik kad si blizu toga da propustiš dan."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Emlékeztetünk, amikor majdnem kihagysz egy napot."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ti invieremo un promemoria quando stai per saltare un giorno."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mēs atgādināsim, kad tu gandrīz palaidīsi garām dienu."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi sender deg en påminnelse når du står i fare for å miste en dag."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We sturen je een herinnering als je een dag dreigt te missen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyślemy Ci przypomnienie, jeśli opuścisz jakiś dzień."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enviaremos um lembrete quando você estiver prestes a perder um dia."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Îți trimitem un memento când ești pe cale să ratezi ziua."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pošleme ti pripomienku, keď hrozí, že deň vynecháš."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opomnili te bomo, ko boš tik pred tem, da izpustiš dan."
