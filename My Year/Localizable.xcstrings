    "Don’t keep it to yourself. The fastest way to make this app better for you is to tell me what’s on your mind.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non tenerlo per te. Il modo più veloce per migliorare questa app per te è dirmi cosa hai in mente."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не тримайте це в собі. Найшвидший спосіб зробити застосунок кращим для вас — сказати мені, що у вас на думці."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No te lo guardes para ti. La forma más rápida de mejorar esta aplicación para ti es decirme qué tienes en mente."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No te lo guardes para ti. La forma más rápida de mejorar esta aplicación para ti es decirme qué tienes en mente."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não guarde isso para você. A maneira mais rápida de tornar este aplicativo melhor para você é me dizer o que você está pensando."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behalte es nicht für dich. Der schnellste Weg, diese App für Sie zu verbessern, besteht darin, mir zu sagen, was Sie denken."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne le gardez pas pour vous. Le moyen le plus rapide d’améliorer cette application pour vous est de me dire ce que vous pensez."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd het niet voor jezelf. De snelste manier om deze app beter voor u te maken, is door mij te vertellen waar u aan denkt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold det ikke for dig selv. Den hurtigste måde at gøre denne app bedre for dig er at fortælle mig, hvad du tænker på."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Håll det inte för dig själv. Det snabbaste sättet att göra den här appen bättre för dig är att berätta för mig vad du tänker på."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikke hold det for deg selv. Den raskeste måten å gjøre denne appen bedre for deg på er å fortelle meg hva du tenker på."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie zatrzymuj tego dla siebie. Najszybszym sposobem na ulepszenie tej aplikacji jest powiedzenie mi, co myślisz."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Älä pidä sitä itselläsi. Nopein tapa tehdä tästä sovelluksesta parempi sinulle on kertoa minulle, mitä ajattelet."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenechávejte si to pro sebe. Nejrychlejší způsob, jak pro vás tuto aplikaci vylepšit, je říct mi, co máte na mysli."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu o ține pentru tine. Cea mai rapidă modalitate de a face această aplicație mai bună pentru tine este să-mi spui la ce te gândești."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne tartsd magadban. A leggyorsabb módja annak, hogy jobbá tegye ezt az alkalmazást, ha elmondja, mi jár a fejében."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenechávajte si to pre seba. Najrýchlejší spôsob, ako zlepšiť túto aplikáciu, je povedať mi, čo máte na mysli."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nemojte to držati za sebe. Najbrži način da poboljšam ovu aplikaciju za vas je da mi kažete što vam je na umu."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne zadržujte tega v sebi. Najhitrejši način, da izboljšamo to aplikacijo za vas, je, da mi poveste, kaj imate na umu."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Ärge hoidke seda enda teada. Kiireim viis selle rakenduse paremaks muutmiseks on öelda mulle, mis teil meeles on."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nepaturiet to pie sevis. Ātrākais veids, kā padarīt šo lietotni jums labāku, ir pastāstīt man, kas jums ir prātā."
          }
        }
      }
    },
