    "A recurring notification on your chosen weekday and time.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A recurring notification on your chosen weekday and time."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Opakované upozornění ve vámi zvolený den v týdnu a čas."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En tilbagevendende notifikation på din valgte ugedag og tidspunkt."
          }
