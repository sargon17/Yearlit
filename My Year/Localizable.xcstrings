          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ekstra påminnelser er tilgjengelige når vanen din har et daglig mål."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodatkowe przypomnienia są dostępne, jeśli Twój nawyk ma dzienny cel."
