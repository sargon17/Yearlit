        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Arhiveerimine peidab selle kalendri teie tahvlite eest, ilma varasemaid andmeid kustutamata."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Arhivējot, šis kalendārs tiek paslēpts no jūsu dēļiem, neizdzēšot iepriekšējos datus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archiving hides this calendar from your boards without deleting past data."
          }
        }
      }
    },
