    "Don't forget to log your habit this week": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non dimenticare di registrare la tua abitudine questa settimana"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не забудьте зареєструвати свою звичку цього тижня"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No olvides registrar tu hábito esta semana."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No olvides registrar tu hábito esta semana."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não se esqueça de registrar seu hábito esta semana"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vergessen Sie nicht, diese Woche Ihre Gewohnheiten zu protokollieren"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "N'oubliez pas d'enregistrer votre habitude cette semaine"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vergeet deze week niet je gewoonte bij te houden"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Glem ikke at logge din vane i denne uge"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Glöm inte att logga din vana den här veckan"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikke glem å loggføre vanen din denne uken"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie zapomnij zapisać swojego nawyku w tym tygodniu"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Älä unohda kirjata tapaasi tällä viikolla"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nezapomeňte si tento týden přihlásit svůj zvyk"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu uitați să vă înregistrați obiceiul în această săptămână"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne felejtse el naplózni szokásait ezen a héten"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nezabudnite si tento týždeň prihlásiť svoj zvyk"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne zaboravite zabilježiti svoju naviku ovaj tjedan"
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta teden ne pozabite zabeležiti svoje navade"
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Ärge unustage sel nädalal oma harjumust kirja panna"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Šonedēļ neaizmirstiet reģistrēt savu ieradumu"
          }
        }
      }
    },
