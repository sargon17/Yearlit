    "This will overwrite %@ %@ within a %@-%@ range.": {
      "comment": "An alert message explaining that applying a new streak will overwrite existing entries. The first argument is the number of days in the streak range. The second argument is whether the streak is daily or weekly.",
      "extractionState": "stale",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "This will overwrite %1$@ %2$@ within a %3$@-%4$@ range."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo sovrascriverà %1$@ %2$@ in un intervallo di %3$@-%4$@."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це перезапише %1$@ %2$@ у діапазоні %3$@-%4$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto sobrescribirá %@%@ dentro de un rango %@-%@."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto sobrescribirá %@%@ dentro de un rango %@-%@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso substituirá %@%@ dentro de um intervalo %@-%@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden %@%@ im Bereich %@-%@ überschrieben."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela écrasera %@%@ dans une plage %@-%@."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hierdoor wordt %@%@ binnen een bereik van %@-%@ overschreven."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil overskrive %@%@ inden for et %@-%@ område."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta kommer att skriva över %@%@ inom intervallet %@-%@."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil overskrive %@%@ innenfor et %@-%@ område."
          }
