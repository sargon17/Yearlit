    "Please enable notifications in Settings to receive reminders.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please enable notifications in Settings to receive reminders."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Chcete-li dostávat připomenutí, povolte upozornění v Nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiver venligst notifikationer i Indstillinger for at modtage påmindelser."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte aktivieren Sie Benachrichtigungen in den Einstellungen, um Erinnerungen zu erhalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilite las notificaciones en Configuración para recibir recordatorios."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Habilite las notificaciones en Configuración para recibir recordatorios."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeldetuletuste saamiseks lubage seadetes märguanded."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ota ilmoitukset käyttöön asetuksista saadaksesi muistutuksia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez activer les notifications dans les paramètres pour recevoir des rappels."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Omogućite obavijesti u Postavkama za primanje podsjetnika."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az emlékeztetők fogadásához engedélyezze az értesítéseket a Beállításokban."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita le notifiche nelle Impostazioni per ricevere promemoria."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lai saņemtu atgādinājumus, lūdzu, iespējojiet paziņojumus sadaļā Iestatījumi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiver varsler i Innstillinger for å motta påminnelser."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel meldingen in Instellingen in om herinneringen te ontvangen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz powiadomienia w Ustawieniach, aby otrzymywać przypomnienia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative as notificações em Configurações para receber lembretes."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Activați notificările în Setări pentru a primi mementouri."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ak chcete dostávať pripomienky, povoľte upozornenia v Nastaveniach."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Če želite prejemati opomnike, omogočite obvestila v nastavitvah."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivera aviseringar i Inställningar för att få påminnelser."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Щоб отримувати нагадування, увімкніть сповіщення в налаштуваннях."
          }
        }
      }
    },
