          "stringUnit": {
            "state": "translated",
            "value": "Yearlit continue de croître, tout comme les personnes qui l'utilisent."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit groeit nog steeds, net als de mensen die het gebruiken."
          }
