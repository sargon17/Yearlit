    "Log a numeric value per day, like pages read or minutes practiced.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra un valore numerico al giorno, come pagine lette o minuti di pratica."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Записуй числове значення щодня, наприклад кількість прочитаних сторінок або хвилин практики."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registre un valor numérico por día, como páginas leídas o minutos practicados."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Registre un valor numérico por día, como páginas leídas o minutos practicados."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Registre um valor numérico por dia, como páginas lidas ou minutos praticados."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Protokollieren Sie einen numerischen Wert pro Tag, z. B. gelesene Seiten oder geübte Minuten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez une valeur numérique par jour, comme les pages lues ou les minutes pratiquées."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Registreer een numerieke waarde per dag, zoals gelezen pagina's of geoefende minuten."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Log en numerisk værdi pr. dag, f.eks. læste sider eller øvede minutter."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Logga ett numeriskt värde per dag, som lästa sidor eller övade minuter."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Logg en numerisk verdi per dag, for eksempel leste sider eller øvede minutter."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejestruj wartość liczbową dziennie, np. przeczytane strony lub przećwiczone minuty."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjaa päiväkohtainen numeerinen arvo, kuten luetut sivut tai harjoitusminuutit."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaznamenejte číselnou hodnotu za den, jako jsou přečtené stránky nebo procvičené minuty."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înregistrați o valoare numerică pe zi, cum ar fi paginile citite sau minutele exersate."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Naplózzon egy numerikus értéket naponta, például az olvasott oldalakat vagy a begyakorolt ​​perceket."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaznamenajte si číselnú hodnotu za deň, napríklad prečítané stránky alebo precvičené minúty."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapišite numeričku vrijednost po danu, poput pročitanih stranica ili uvježbanih minuta."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zabeležite številčno vrednost na dan, na primer prebrane strani ali vajene minute."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Logige päeva kohta arvväärtusi, näiteks loetud lehekülgi või harjutatud minutit."
