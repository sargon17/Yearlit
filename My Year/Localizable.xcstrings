    "Use the new view to make every completed day feel like visible proof you showed up.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la nuova vista per far sembrare ogni giorno completato una prova visibile della tua costanza."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використовуй новий вигляд, щоб кожен завершений день був видимим доказом твоєї присутності."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la nueva vista para que cada día completado se sienta como una prueba visible de tu constancia."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la nueva vista para que cada día completado se sienta como una prueba visible de tu constancia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a nova visualização para transformar cada dia concluído em uma prova visível da sua constância."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutzen Sie die neue Ansicht, damit sich jeder abgeschlossene Tag wie ein sichtbarer Beweis dafür anfühlt, dass Sie da waren."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez la nouvelle vue pour que chaque journée terminée ressemble à une preuve visible de votre présence."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik de nieuwe weergave om elke voltooide dag te laten voelen als een zichtbaar bewijs dat u bent verschenen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Brug den nye visning til at få hver fuldendt dag til at føles som et synligt bevis på, at du dukkede op."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd den nya vyn för att få varje avslutad dag att kännas som ett synligt bevis på att du dök upp."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruk den nye visningen for å få hver fullført dag til å føles som et synlig bevis på at du dukket opp."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skorzystaj z nowego widoku, aby każdy ukończony dzień był widocznym dowodem na to, że się pojawiłeś."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käytä uutta näkymää saadaksesi jokaisen täytetyn päivän tuntumaan näkyvältä todisteelta, että olet paikalla."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Použijte nové zobrazení, aby každý dokončený den vypadal jako viditelný důkaz, že jste se ukázali."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizați noua vizualizare pentru a face ca fiecare zi încheiată să se simtă ca o dovadă vizibilă că ați apărut."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Használja az új nézetet, hogy minden befejezett napot látható bizonyítéknak érezze, hogy megjelent."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Použite nové zobrazenie, aby sa každý dokončený deň cítil ako viditeľný dôkaz, že ste sa ukázali."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Upotrijebite novi prikaz kako biste svaki odrađeni dan osjećali kao vidljiv dokaz da ste se pojavili."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uporabite nov pogled, da bo vsak zaključen dan videti kot viden dokaz, da ste se pojavili."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kasutage uut vaadet, et iga lõppenud päev tunduks nähtava tõendina, et kohale ilmusite."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Izmantojiet jauno skatu, lai katra pabeigtā diena justos kā redzams pierādījums, ka parādījāties."
          }
        }
      }
    },
