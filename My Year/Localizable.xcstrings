    "iOS does not allow apps to set wallpaper directly. Test final application on a physical iPhone." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS neumožňuje aplikacím nastavovat tapetu přímo. Finální použití otestujte na fyzickém iPhonu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS tillader ikke apps at indstille baggrundsbilledet direkte. Test den endelige anvendelse på en fysisk iPhone."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS erlaubt Apps nicht, Hintergrundbilder direkt festzulegen. Teste die endgültige Anwendung auf einem echten iPhone."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS does not allow apps to set wallpaper directly. Test final application on a physical iPhone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS no permite que las apps establezcan fondos directamente. Prueba la aplicación final en un iPhone físico."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS no permite que las apps establezcan fondos directamente. Prueba la aplicación final en un iPhone físico."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS ei luba rakendustel taustapilti otse määrata. Testi lõplikku rakendamist füüsilisel iPhone’il."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS ei salli sovellusten asettaa taustakuvaa suoraan. Testaa lopullinen käyttö fyysisellä iPhonella."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS n’autorise pas les apps à définir directement le fond d’écran. Teste l’application finale sur un iPhone physique."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS ne dopušta aplikacijama izravno postavljanje pozadine. Završnu primjenu testiraj na fizičkom iPhoneu."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az iOS nem engedi, hogy az appok közvetlenül állítsanak be háttérképet. A végső alkalmazást fizikai iPhone-on teszteld."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS non consente alle app di impostare direttamente lo sfondo. Testa l’applicazione finale su un iPhone fisico."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS neļauj lietotnēm tieši iestatīt fona attēlu. Pārbaudi galīgo lietošanu fiziskā iPhone."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS lar ikke apper angi bakgrunn direkte. Test den ferdige løsningen på en fysisk iPhone."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS staat niet toe dat apps je achtergrond direct instellen. Test de uiteindelijke toepassing op een fysieke iPhone."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS nie pozwala aplikacjom ustawiać tapety bezpośrednio. Przetestuj końcowe zastosowanie na fizycznym iPhonie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O iOS não permite que apps definam o papel de parede diretamente. Teste a aplicação final em um iPhone físico."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS nu permite aplicațiilor să seteze fundalul direct. Testează aplicarea finală pe un iPhone fizic."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS neumožňuje aplikáciám nastavovať tapetu priamo. Finálne použitie otestuj na fyzickom iPhone."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS aplikacijam ne dovoljuje neposredne nastavitve ozadja. Končno uporabo preizkusi na fizičnem iPhonu."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS tillåter inte appar att ställa in bakgrunden direkt. Testa den slutliga tillämpningen på en fysisk iPhone."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS не дозволяє програмам напряму встановлювати шпалери. Перевірте остаточне застосування на фізичному iPhone."
          }
        }
      }
    },
    "iOS does not let apps open the widget picker directly. Add it from the Home Screen." : {
