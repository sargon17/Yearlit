    "Weekly calendars only send one reminder on the selected weekday." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Týdenní kalendáře odesílají pouze jedno připomenutí ve vybraný den v týdnu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ugentlige kalendere sender kun én påmindelse på den valgte ugedag."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wöchentliche Kalender senden nur eine Erinnerung am ausgewählten Wochentag."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weekly calendars only send one reminder on the selected weekday."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los calendarios semanales solo envían un recordatorio en el día de la semana seleccionado."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los calendarios semanales solo envían un recordatorio en el día de la semana seleccionado."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nädalakalendrid saadavad valitud nädalapäeval ainult ühe meeldetuletuse."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Viikkokalenterit lähettävät vain yhden muistutuksen valittuna viikonpäivänä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les calendriers hebdomadaires n'envoient qu'un seul rappel le jour de la semaine sélectionné."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tjedni kalendari šalju samo jedan podsjetnik na odabrani dan u tjednu."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A heti naptárak csak egy emlékeztetőt küldenek a kiválasztott hétköznapon."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I calendari settimanali inviano solo un promemoria nel giorno della settimana selezionato."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nedēļas kalendāri atlasītajā nedēļas dienā nosūta tikai vienu atgādinājumu."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ukekalendere sender kun én påminnelse på den valgte ukedagen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Weekkalenders sturen slechts één herinnering op de geselecteerde weekdag."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kalendarze tygodniowe wysyłają tylko jedno przypomnienie w wybrany dzień tygodnia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
