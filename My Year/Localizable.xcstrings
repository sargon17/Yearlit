    "No empty months. No feeling late. Just the year you’re actually building.": {
      "comment": "A description of the \"Your 365\" feature, emphasizing the sense of accomplishment and purpose that comes with building a year one day at a time.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Niente mesi vuoti. Niente sensazione di essere in ritardo. Solo l'anno che stai davvero costruendo."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
