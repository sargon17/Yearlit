    "No empty months. No feeling late. Just the year you’re actually building.": {
      "comment": "A description of the \"Your 365\" feature, emphasizing the sense of accomplishment and purpose that comes with building a year one day at a time.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Niente mesi vuoti. Niente sensazione di essere in ritardo. Solo l'anno che stai davvero costruendo."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Жодних порожніх місяців. Жодного відчуття запізнення. Лише рік, який ти справді будуєш."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay meses vacíos. Sin sensación de retraso. Justo el año en el que realmente estás construyendo."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay meses vacíos. Sin sensación de retraso. Justo el año en el que realmente estás construyendo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não há meses vazios. Não há sensação de atraso. Apenas o ano em que você está realmente construindo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Keine leeren Monate. Kein Gefühl der Verspätung. Nur das Jahr, in dem Sie tatsächlich bauen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas de mois vides. Pas de sentiment de retard. Juste l’année où vous construisez réellement."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen lege maanden. Geen gevoel van laat. Precies het jaar waarin u daadwerkelijk bouwt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen tomme måneder. Ingen følelse sent. Bare det år, du faktisk bygger."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inga tomma månader. Ingen känsla sen. Bara året du faktiskt bygger."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen tomme måneder. Ingen følelse sent. Akkurat året du faktisk bygger."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Żadnych pustych miesięcy. Nie ma uczucia spóźnienia. Tylko rok, w którym faktycznie budujesz."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ei tyhjiä kuukausia. Ei myöhästymisen tunnetta. Vain vuosi, jolloin rakennat."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Žádné prázdné měsíce. Žádný pocit zpoždění. Jen rok, kdy skutečně stavíte."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fără luni goale. Fără senzație de întârziere. Doar anul în care construiești de fapt."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincsenek üres hónapok. Nincs késői érzés. Csak abban az évben, amikor valójában épít."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Žiadne prázdne mesiace. Žiadny pocit oneskorenia. Len rok, kedy skutočne staviate."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nema praznih mjeseci. Nema osjećaja kasno. Samo godina koju zapravo gradite."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ni praznih mesecev. Brez občutka zamude. Samo leto, ki ga dejansko gradite."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Ei ühtegi tühja kuud. Pole hilinenud tunnet. Just see aasta, mil te tegelikult ehitate."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nav tukšu mēnešu. Nav kavēšanās. Tikai gads, kurā jūs faktiski veidojat."
          }
        }
      }
    },
