    "A gentle daily nudge helps your dots keep growing.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A gentle daily nudge helps your dots keep growing."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jemné každodenní pošťuchování pomáhá vašim tečkám neustále růst."
