    "Use the new view to make every completed day feel like visible proof you showed up." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "V novém zobrazení je každý splněný den viditelný důkaz, že pokračuješ."
