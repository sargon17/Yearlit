    "Yearlit is still growing — just like the people who use it.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit è ancora in crescita — proprio come le persone che lo usano."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit все ще зростає — як і люди, які ним користуються."
          }
        },
