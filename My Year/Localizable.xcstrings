        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ikke hold det for deg selv. Den raskeste måten å gjøre denne appen bedre for deg på er å fortelle meg hva du tenker på."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Houd het niet voor jezelf. De snelste manier om deze app beter voor je te maken, is vertellen wat je mist."
