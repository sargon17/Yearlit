    "Couldn’t load plans. Check your connection and try again.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t load plans. Check your connection and try again."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Plány se nepodařilo načíst. Zkontrolujte připojení a zkuste to znovu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Planerne kunne ikke indlæses. Tjek din forbindelse, og prøv igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pläne konnten nicht geladen werden. Überprüfen Sie Ihre Verbindung und versuchen Sie es erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron cargar los planes. Comprueba tu conexión y vuelve a intentarlo."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron cargar los planes. Comprueba tu conexión y vuelve a intentarlo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Plaate ei saanud laadida. Kontrollige ühendust ja proovige uuesti."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Suunnitelmia ei voitu ladata. Tarkista yhteys ja yritä uudelleen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger les plans. Vérifiez votre connexion et réessayez."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nije moguće učitati planove. Provjerite vezu i pokušajte ponovno."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A terveket nem sikerült betölteni. Ellenőrizze a kapcsolatot, és próbálja újra."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile caricare i piani. Controlla la connessione e riprova."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nevarēja ielādēt plānus. Pārbaudiet savienojumu un mēģiniet vēlreiz."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunne ikke laste inn planer. Sjekk tilkoblingen og prøv igjen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan plannen niet laden. Controleer uw verbinding en probeer het opnieuw."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie można załadować planów. Sprawdź połączenie i spróbuj ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível carregar os planos. Verifique sua conexão e tente novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Planurile nu au putut fi încărcate. Verificați conexiunea și încercați din nou."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Plány sa nepodarilo načítať. Skontrolujte pripojenie a skúste to znova."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Načrtov ni bilo mogoče naložiti. Preverite povezavo in poskusite znova."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det gick inte att läsa in planer. Kontrollera din anslutning och försök igen."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося завантажити плани. Перевірте підключення та повторіть спробу."
          }
        }
      }
    },
