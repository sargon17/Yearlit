    "Debug only. Opens the milestone sheet without changing tracker state.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo debug. Apre il foglio del traguardo senza modificare lo stato del tracker."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Лише для debug. Відкриває аркуш етапу без зміни стану трекера."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sólo depurar. Abre la hoja de hitos sin cambiar el estado del rastreador."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Sólo depurar. Abre la hoja de hitos sin cambiar el estado del rastreador."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Somente depuração. Abre a planilha de marcos sem alterar o estado do rastreador."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur Debuggen. Öffnet das Meilensteinblatt, ohne den Tracker-Status zu ändern."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Débogage uniquement. Ouvre la feuille de jalon sans changer l'état du tracker."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alleen debuggen. Opent het mijlpalenblad zonder de trackerstatus te wijzigen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Debug kun. Åbner milepælsarket uden at ændre trackertilstand."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Endast felsökning. Öppnar milstolpsarket utan att ändra spårningsstatus."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bare feilsøking. Åpner milepælsarket uten å endre sporingsstatus."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tylko debugowanie. Otwiera arkusz kamieni milowych bez zmiany stanu modułu śledzącego."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vain virheenkorjaus. Avaa virstanpylvästaulukon muuttamatta seurannan tilaa."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pouze ladění. Otevře tabulku milníků bez změny stavu sledování."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Doar depanare. Deschide foaia de reper fără a schimba starea urmăritorului."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Csak hibakeresés. Megnyitja a mérföldkő lapot a nyomkövető állapotának megváltoztatása nélkül."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Iba ladenie. Otvorí hárok míľnikov bez zmeny stavu sledovania."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Samo otklanjanje pogrešaka. Otvara list s prekretnicama bez promjene stanja alata za praćenje."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Samo odpravljanje napak. Odpre list z mejniki brez spreminjanja stanja sledilnika."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainult silumine. Avab verstaposti lehe jälgija olekut muutmata."
          }
