    "It's never late to start a new streak!": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It's never late to start a new streak!"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nikdy není pozdě začít novou sérii!"
          }
        },
