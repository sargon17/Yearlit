    "To make habits stick, keep them:": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per rendere le abitudini durature, mantienile:"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Щоб звички закріпилися, зроби їх:"
          }
        },
        "es": {
          "stringUnit": {
