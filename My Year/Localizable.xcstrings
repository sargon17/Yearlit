        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C’est la force tranquille qui transforme de petites actions ordinaires en résultats extraordinaires au fil du temps."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To je tiha sila koja male, obične radnje s vremenom pretvara u velike rezultate."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ez az a csendes erő, amely az apró, hétköznapi cselekedeteket idővel rendkívüli eredményekké változtatja."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "È la forza silenziosa che trasforma piccole azioni ordinarie in risultati straordinari nel tempo."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tas ir klusais spēks, kas laika gaitā pārvērš mazas ikdienas darbības lielos rezultātos."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det er den stille kraften som gjør små, vanlige handlinger til ekstraordinære resultater over tid."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het is de stille kracht die kleine, gewone acties in de loop van de tijd omzet in buitengewone resultaten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
