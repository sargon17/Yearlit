            "value": "Führen Sie ein Upgrade auf Premium durch, um weitere Zeiten hinzuzufügen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Passez à Premium pour ajouter plus de fois."
          }
