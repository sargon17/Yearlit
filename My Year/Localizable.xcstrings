          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby utrwalić nawyki, utrzymuj je:"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jotta tottumukset pysyvät kiinni, säilytä ne:"
          }
        },
        "cs": {
          "stringUnit": {
