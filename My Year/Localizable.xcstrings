            "value": "Glöm inte att spåra %@ den här veckan! (Mål:%d)"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikke glem å spore %@ denne uken! (Mål:%d)"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie zapomnij śledzić%@ w tym tygodniu! (Cel:%d)"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Älä unohda seurata %@ tällä viikolla! (Tavoite:%d)"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nezapomeňte tento týden sledovat %@! (Cíl:%d)"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu uitați să urmăriți %@ săptămâna aceasta! (țintă:%d)"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne felejtse el követni a %@ eseményt ezen a héten! (Cél:%d)"
