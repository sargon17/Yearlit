    "Use the Daily Wallpaper output. Turn Show Preview off.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the Daily Wallpaper output. Turn Show Preview off."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa l’output Sfondo giornaliero. Disattiva Mostra anteprima."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Використайте результат «Щоденні шпалери». Вимкніть «Показувати перегляд»."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la salida de Fondo diario. Desactiva Mostrar vista previa."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la salida de Fondo diario. Desactiva Mostrar vista previa."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a saída de Papel de parede diário. Desative Mostrar prévia."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutze die Ausgabe „Tägliches Hintergrundbild“. Deaktiviere „Vorschau anzeigen“."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilise la sortie Fond d’écran quotidien. Désactive Afficher l’aperçu."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik de uitvoer Dagelijkse achtergrond. Zet Toon voorvertoning uit."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Brug outputtet Dagligt baggrundsbillede. Slå Vis forhåndsvisning fra."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd utdata från Daglig bakgrund. Stäng av Visa förhandsvisning."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruk utdata fra Daglig bakgrunn. Slå av Vis forhåndsvisning."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Użyj wyniku Codzienna tapeta. Wyłącz Pokaż podgląd."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Käytä Päivittäinen taustakuva -tulostetta. Poista Näytä esikatselu käytöstä."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Použijte výstup Denní tapeta. Vypněte Zobrazit náhled."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Folosește rezultatul Fundal zilnic. Dezactivează Afișează previzualizarea."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Használd a Napi háttérkép kimenetét. Kapcsold ki az Előnézet megjelenítése beállítást."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Použi výstup Denná tapeta. Vypni Zobraziť ukážku."
          }
        },
        "hr": {
