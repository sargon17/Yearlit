        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ai făcut-o săptămâna trecută, poți să o faci săptămâna asta! 💚"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Múlt héten megcsináltad, ezen a héten megteheted! 💚"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Dokázali ste to minulý týždeň, dokážete to aj tento týždeň! 💚"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uspjeli ste prošli tjedan, možete i ovaj tjedan! 💚"
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prejšnji teden vam je uspelo, ta teden lahko! 💚"
