    "The more visible your habit is, the easier it is to return." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Čím víc máš návyk na očích, tím snáz se k němu vrátíš."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jo mere synlig din vane er, desto lettere er den at vende tilbage til."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je sichtbarer deine Gewohnheit ist, desto leichter kommst du zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The more visible your habit is, the easier it is to return."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuanto más visible sea tu hábito, más fácil será volver a él."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mientras más visible sea tu hábito, más fácil será retomarlo."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mida nähtavam on harjumus, seda lihtsam on tagasi tulla."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitä näkyvämpi tapasi on, sitä helpompi siihen on palata."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plus ton habitude est visible, plus c’est facile d’y revenir."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Što je navika vidljivija, lakše joj se vratiti."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minél láthatóbb a szokásod, annál könnyebb visszatérni hozzá."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Più l'abitudine resta in vista, più è facile tornarci."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jo redzamāks ir ieradums, jo vieglāk pie tā atgriezties."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jo mer synlig vanen er, desto enklere er det å komme tilbake."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hoe zichtbaarder je gewoonte is, hoe makkelijker je terugkomt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Im bardziej widoczny jest nawyk, tym łatwiej do niego wrócić."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quanto mais visível o hábito, mais fácil voltar para ele."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cu cât obiceiul e mai vizibil, cu atât revii mai ușor la el."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Čím viac máš zvyk na očiach, tým ľahšie sa k nemu vrátiš."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bolj ko je navada vidna, lažje se vrneš k njej."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ju synligare vanan är, desto lättare är det att komma tillbaka."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чим видиміша звичка, тим легше до неї повернутися."
          }
        }
      }
    },
    "The truth? I’ve never been naturally consistent." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pravda? Pravidelnost mi nikdy nešla sama."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sandheden? Jeg har aldrig været naturlig konsekvent."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Wahrheit? Beständigkeit fiel mir nie von selbst leicht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿La verdad? Nunca he sido naturalmente consistente."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿La verdad? Nunca he sido naturalmente consistente."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tõde? Ma pole kunagi olnud loomulikult järjekindel."
