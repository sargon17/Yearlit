    "Archiving hides this calendar from your boards without deleting past data.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'archiviazione nasconde questo calendario dalle tue bacheche senza eliminare i dati passati."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Архівування приховує цей календар із ваших дошок, не видаляючи минулі дані."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivar oculta este calendario de tus tableros sin eliminar datos anteriores."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivar oculta este calendario de tus tableros sin eliminar datos anteriores."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O arquivamento oculta este calendário dos seus quadros sem excluir os dados anteriores."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch die Archivierung wird dieser Kalender vor Ihren Pinnwänden ausgeblendet, ohne dass frühere Daten gelöscht werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'archivage masque ce calendrier de vos tableaux sans supprimer les données passées."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Door te archiveren verbergt u deze kalender voor uw borden zonder eerdere gegevens te verwijderen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkivering skjuler denne kalender fra dine tavler uden at slette tidligere data."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkivering döljer den här kalendern från dina anslagstavlor utan att radera tidigare data."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkivering skjuler denne kalenderen fra tavlene dine uten å slette tidligere data."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Archiwizacja ukrywa ten kalendarz przed Twoimi tablicami bez usuwania wcześniejszych danych."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkistointi piilottaa tämän kalenterin tauluiltasi poistamatta aiempia tietoja."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivace skryje tento kalendář z vašich nástěnek, aniž by došlo ke smazání minulých dat."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Arhivarea ascunde acest calendar din panourile dvs. fără a șterge datele anterioare."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az archiválás elrejti ezt a naptárt a táblákról a korábbi adatok törlése nélkül."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivácia skryje tento kalendár z vašich tabúľ bez odstránenia minulých údajov."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arhiviranje skriva ovaj kalendar s vaših ploča bez brisanja prošlih podataka."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Arhiviranje skrije ta koledar pred vašimi tablami, ne da bi izbrisali pretekle podatke."
