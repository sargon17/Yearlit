    "Watch your chain grow.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda crescere la tua serie."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Спостерігай, як росте твій ланцюжок."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira cómo crece tu cadena."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira cómo crece tu cadena."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja sua corrente crescer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beobachten Sie, wie Ihre Kette wächst."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Regardez votre chaîne grandir."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zie hoe uw ketting groeit."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Se din kæde vokse."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Se din kedja växa."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Se kjeden din vokse."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Obserwuj, jak rośnie Twój łańcuch."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Katso ketjusi kasvamista."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledujte, jak váš řetěz roste."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Urmăriți-vă cum crește lanțul."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nézze meg a lánc növekedését."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledujte, ako vaša reťaz rastie."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gledajte kako vaš lanac raste."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opazujte rast svoje verige."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaadake, kuidas teie kett kasvab."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skatieties, kā jūsu ķēde aug."
          }
        }
      }
    },
    "We will send you a reminder when you're about to miss a day.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ti invieremo un promemoria quando stai per saltare un giorno."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми надішлемо нагадування, коли є ризик пропустити день."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Le enviaremos un recordatorio cuando esté a punto de perderse un día."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Le enviaremos un recordatorio cuando esté a punto de perderse un día."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviaremos um lembrete quando você estiver prestes a perder um dia."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir senden Ihnen eine Erinnerung, wenn Sie einen Tag verpassen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous vous enverrons un rappel lorsque vous êtes sur le point de manquer une journée."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wanneer u een dag gaat missen, sturen wij u een herinnering."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi sender dig en påmindelse, når du er ved at gå glip af en dag."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi skickar en påminnelse till dig när du är på väg att missa en dag."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi sender deg en påminnelse når du er i ferd med å gå glipp av en dag."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyślemy Ci przypomnienie, jeśli opuścisz jakiś dzień."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lähetämme sinulle muistutuksen, kun jokin päivä jää väliin."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Když zmeškáte některý den, zašleme vám připomenutí."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Vă vom trimite un memento când sunteți pe cale să pierdeți o zi."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Emlékeztetőt küldünk, ha kihagy egy napot."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Keď zmeškáte niektorý deň, pošleme vám pripomenutie."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Poslat ćemo vam podsjetnik kada budete trebali propustiti dan."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ko boste zamudili dan, vam bomo poslali opomnik."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Saadame teile meeldetuletuse, kui teil jääb mõni päev vahele."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mēs nosūtīsim jums atgādinājumu, kad grasāties palaist garām kādu dienu."
          }
        }
      }
    },
    "We’ll make this better together — one step, one habit, one consistent day at a time.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo miglioreremo insieme — un passo, un'abitudine, una giornata costante alla volta."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Я зроблю це кращим разом із вами — крок за кроком, звичка за звичкою, день за днем."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Juntos mejoraremos esto: un paso, un hábito, un día constante a la vez."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Juntos mejoraremos esto: un paso, un hábito, un día constante a la vez."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Juntos tornaremos isso melhor – um passo, um hábito, um dia consistente de cada vez."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir werden es gemeinsam besser machen – ein Schritt, eine Gewohnheit, ein konsequenter Tag nach dem anderen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous améliorerons les choses ensemble – une étape, une habitude, une journée cohérente à la fois."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We zullen dit samen verbeteren – één stap, één gewoonte, één consistente dag tegelijk."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi vil gøre dette bedre sammen - et skridt, en vane, en konsekvent dag ad gangen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi kommer att göra det här bättre tillsammans – ett steg, en vana, en konsekvent dag i taget."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi vil gjøre dette bedre sammen - ett skritt, en vane, en konsekvent dag om gangen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Razem sprawimy, że będzie lepiej – jeden krok, jeden nawyk, jeden konsekwentny dzień na raz."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Teemme tästä paremman yhdessä – yksi askel, yksi tapa, yksi johdonmukainen päivä kerrallaan."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Společně to vylepšíme – jeden krok, jeden zvyk, jeden konzistentní den po druhém."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Împreună vom face acest lucru mai bun - un pas, un obicei, o zi constantă la un moment dat."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Együtt jobbá tesszük ezt – egy lépés, egy szokás, egy-egy következetes nap."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Spolu to vylepšíme – jeden krok, jeden zvyk, jeden konzistentný deň za druhým."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Učinit ćemo ovo boljim zajedno - jedan korak, jedna navika, jedan dosljedan dan po jedan."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skupaj bomo to izboljšali – en korak, ena navada, en dosleden dan za dnem."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Teeme selle koos paremaks – üks samm, üks harjumus, üks järjepidev päev korraga."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mēs to padarīsim labāk kopā — viens solis, viens ieradums, viena konsekventa diena vienlaikus."
          }
        }
      }
    },
