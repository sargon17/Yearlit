    "Don’t just set goals": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non limitarti a fissare obiettivi"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не просто ставте цілі"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No te limites a establecer objetivos"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No te limites a establecer objetivos"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não se limite a definir metas"
          }
        },
        "de": {
