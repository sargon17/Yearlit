    "Choose the promise you want to keep this year.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the promise you want to keep this year."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte si slib, který chcete letos dodržet."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg det løfte, du vil holde i år."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie das Versprechen, das Sie dieses Jahr einhalten möchten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige la promesa que deseas cumplir este año."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige la promesa que deseas cumplir este año."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Valige lubadus, mida soovite sellel aastal täita."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse lupaus, jonka haluat pitää tänä vuonna."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez la promesse que vous souhaitez tenir cette année."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberite obećanje koje želite održati ove godine."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válassza ki azt az ígéretet, amelyet idén be kíván tartani."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli la promessa che vuoi mantenere quest'anno."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Izvēlieties solījumu, kuru vēlaties izpildīt šogad."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg løftet du vil holde i år."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies de belofte die je dit jaar wilt nakomen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz obietnicę, której chcesz dotrzymać w tym roku."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a promessa que deseja cumprir este ano."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alegeți promisiunea pe care doriți să o respectați anul acesta."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte si sľub, ktorý chcete tento rok dodržať."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Izberite obljubo, ki jo želite letos držati."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj det löfte du vill hålla i år."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть обіцянку, яку ви хочете виконати цього року."
          }
        }
      }
    },
    "Yearlit will help you prove it, one day at a time.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit will help you prove it, one day at a time."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit vám to pomůže dokázat, jeden den po druhém."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit hjælper dig med at bevise det, en dag ad gangen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit wird Ihnen dabei helfen, es Tag für Tag zu beweisen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit te ayudará a demostrarlo, un día a la vez."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit te ayudará a demostrarlo, un día a la vez."
          }
        },
