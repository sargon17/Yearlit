            "value": "Aby návyky zůstaly zachovány, udržujte je:"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pentru ca obiceiurile să rămână, păstrați-le:"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A szokások megtartásához tartsa meg őket:"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby sa návyky udržali, dodržujte ich:"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Da bi se navike zadržale, zadržite ih:"
          }
        },
        "sl": {
          "stringUnit": {
