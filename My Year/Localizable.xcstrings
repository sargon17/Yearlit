    "Unlock deeper stats, widgets, and more room to track your year.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca statistiche più approfondite, widget e più spazio per tenere traccia del tuo anno."
