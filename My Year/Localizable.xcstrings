    " After this, your year is ready." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pak je tvůj rok připravený."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Derefter er dit år klar."
