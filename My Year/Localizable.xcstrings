    "A quick check-in can help you keep momentum.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un rapido check-in può aiutarti a mantenere lo slancio."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Швидка реєстрація може допомогти вам зберегти імпульс."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un control rápido puede ayudarle a mantener el impulso."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Un control rápido puede ayudarle a mantener el impulso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um check-in rápido pode ajudá-lo a manter o ritmo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein schneller Check-in kann Ihnen helfen, in Schwung zu bleiben."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un enregistrement rapide peut vous aider à maintenir votre élan."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een snelle check-in kan u helpen de vaart erin te houden."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En hurtig check-in kan hjælpe dig med at holde momentum."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En snabb incheckning kan hjälpa dig att hålla farten."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En rask innsjekking kan hjelpe deg med å holde farten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Szybka rejestracja pomoże Ci utrzymać dynamikę."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nopea sisäänkirjautuminen voi auttaa sinua pitämään vauhtia."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Rychlý check-in vám pomůže udržet tempo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "O înregistrare rapidă vă poate ajuta să vă mențineți impulsul."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A gyors bejelentkezés segíthet lendületben tartani."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Rýchla registrácia vám môže pomôcť udržať tempo."
          }
        },
