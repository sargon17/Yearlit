    "Start with something small enough to do even on a hard day.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start with something small enough to do even on a hard day."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Začněte s něčím, co je dostatečně malé, abyste mohli dělat i v náročných dnech."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Start med noget lille nok til at gøre selv på en hård dag."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beginnen Sie mit etwas, das klein genug ist, um es auch an einem anstrengenden Tag zu tun."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comience con algo lo suficientemente pequeño como para hacerlo incluso en un día difícil."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Comience con algo lo suficientemente pequeño como para hacerlo incluso en un día difícil."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Alusta millestki, mis on piisavalt väike, et seda teha ka raskel päeval."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Aloita jostain tarpeeksi pienestä tehdäksesi vaikeanakin päivänä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez par quelque chose d'assez petit à faire même lors d'une dure journée."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Počnite s nečim dovoljno malim da možete učiniti čak i na naporan dan."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kezdje valami elég kicsivel, hogy még egy nehéz napon is megcsinálja."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia con qualcosa di abbastanza piccolo da fare anche in una giornata difficile."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sāciet ar kaut ko pietiekami mazu, lai to izdarītu pat grūtā dienā."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Begynn med noe lite nok til å gjøre selv på en hard dag."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Begin met iets dat klein genoeg is om zelfs op een zware dag te doen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zacznij od czegoś na tyle małego, że możesz to zrobić nawet w ciężki dzień."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece com algo pequeno o suficiente para ser feito mesmo em um dia difícil."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Începeți cu ceva suficient de mic pentru a face chiar și într-o zi grea."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Začnite s niečím dostatočne malým, čo môžete urobiť aj v náročnom dni."
