    "End date must be today or earlier.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "End date must be today or earlier."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Datum ukončení musí být dnes nebo dříve."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Slutdatoen skal være i dag eller tidligere."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Enddatum muss heute oder früher liegen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La fecha de finalización debe ser hoy o antes."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "La fecha de finalización debe ser hoy o antes."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Lõppkuupäev peab olema tänane või varasem."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Päättymispäivän on oltava tänään tai aikaisempi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La date de fin doit être aujourd'hui ou avant."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Datum završetka mora biti danas ili ranije."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A befejezés dátumának ma vagy korábbinak kell lennie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La data di fine deve essere oggi o precedente."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Beigu datumam ir jābūt šodienai vai agrākam."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sluttdatoen må være i dag eller tidligere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De einddatum moet vandaag of eerder zijn."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Data zakończenia musi przypadać dzisiaj lub wcześniej."
          }
