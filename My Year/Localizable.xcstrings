          "stringUnit": {
            "state": "translated",
            "value": "Kom tilbake når du er klar. I dag fungerer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wróć, kiedy będziesz gotowy. Dzisiaj działa."
