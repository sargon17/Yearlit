    "Skips the reminder if you already logged today." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přeskočí připomenutí, pokud jste se již dnes přihlásili."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Springer påmindelsen over, hvis du allerede er logget i dag."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überspringt die Erinnerung, wenn du heute schon eingetragen hast."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omite el recordatorio si ya inició sesión hoy."
