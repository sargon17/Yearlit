    "Track a simple yes/no each day. Great for habits you either complete or skip.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra un semplice sì/no ogni giorno. Ideale per abitudini che completi o salti."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відмічай просте так/ні щодня. Чудово для звичок, які або виконуються, або ні."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Realice un seguimiento de un simple sí o no cada día. Ideal para hábitos que completas o te saltas."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Realice un seguimiento de un simple sí o no cada día. Ideal para hábitos que completas o te saltas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acompanhe um simples sim/não todos os dias. Ótimo para hábitos que você completa ou pula."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolgen Sie jeden Tag ein einfaches Ja/Nein. Ideal für Gewohnheiten, die Sie entweder vervollständigen oder überspringen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez un simple oui/non chaque jour. Idéal pour les habitudes que vous complétez ou sautez."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd elke dag een eenvoudig ja/nee bij. Ideaal voor gewoontes die je afmaakt of overslaat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spor et simpelt ja/nej hver dag. Fantastisk til vaner, du enten gennemfører eller springer over."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spåra ett enkelt ja/nej varje dag. Perfekt för vanor du antingen slutför eller hoppar över."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Spor et enkelt ja/nei hver dag. Flott for vaner du enten fullfører eller hopper over."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Śledź proste tak/nie każdego dnia. Świetne w przypadku nawyków, które albo dokończysz, albo pominiesz."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Seuraa yksinkertaista kyllä/ei joka päivä. Erinomainen tottumuksiin, jotka joko suoritat loppuun tai ohitat."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledujte jednoduché ano/ne každý den. Skvělé pro návyky, které buď dokončíte, nebo vynecháte."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Urmăriți un simplu da/nu în fiecare zi. Excelent pentru obiceiurile pe care fie le completați, fie le omiteți."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kövesse nyomon az egyszerű igen/nem válaszokat minden nap. Nagyszerű azokhoz a szokásokhoz, amelyeket befejezett vagy kihagy."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledujte jednoduché áno/nie každý deň. Skvelé pre návyky, ktoré buď dokončíte alebo preskočíte."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pratite jednostavno da/ne svaki dan. Izvrsno za navike koje završite ili preskočite."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vsak dan sledite preprostemu da/ne. Odlično za navade, ki jih dokončate ali preskočite."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Jälgige iga päev lihtsat jah/ei. Suurepärane harjumuste jaoks, mille te lõpetate või jätate vahele."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Katru dienu izsekojiet vienkāršu jā/nē. Lieliski piemērots paradumiem, kurus pabeidzat vai izlaižat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track a simple yes/no each day. Great for habits you either complete or skip."
          }
        }
      }
    },
