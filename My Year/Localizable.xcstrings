    "We’ll make this better together — one step, one habit, one consistent day at a time." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Společně to zlepšíme: jeden krok, jeden návyk, jeden pravidelný den za druhým."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi vil gøre dette bedre sammen - et skridt, en vane, en konsekvent dag ad gangen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wir machen Yearlit gemeinsam besser - ein Schritt, eine Gewohnheit, ein beständiger Tag nach dem anderen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Juntos mejoraremos esto: un paso, un hábito, un día constante a la vez."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Juntos mejoraremos esto: un paso, un hábito, un día constante a la vez."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teeme selle koos paremaks – üks samm, üks harjumus, üks järjepidev päev korraga."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Teemme tästä paremman yhdessä – yksi askel, yksi tapa, yksi johdonmukainen päivä kerrallaan."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nous améliorerons les choses ensemble – une étape, une habitude, une journée cohérente à la fois."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Učinit ćemo ovo boljim zajedno — korak po korak, naviku po naviku, dosljedan dan po dan."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Együtt jobbá tesszük ezt – egy lépés, egy szokás, egy-egy következetes nap."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo miglioreremo insieme — un passo, un'abitudine, una giornata costante alla volta."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mēs to uzlabosim kopā — pa vienam solim, vienam ieradumam, vienai noturīgai dienai."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi gjør dette bedre sammen: ett steg, én vane og én dag av gangen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We zullen dit samen verbeteren – één stap, één gewoonte, één consistente dag tegelijk."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Razem sprawimy, że będzie lepiej – jeden krok, jeden nawyk, jeden konsekwentny dzień na raz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vamos melhorar isso juntos: um passo, um hábito e um dia consistente de cada vez."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Îl facem mai bun împreună — un pas, un obicei, o zi consecventă pe rând."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spolu to zlepšíme: krok za krokom, zvyk za zvykom, jeden pravidelný deň po druhom."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skupaj bomo to izboljšali: korak za korakom, navado za navado, dosleden dan za dnem."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vi gör det här bättre tillsammans, ett steg, en vana och en dag i taget."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Я зроблю це кращим разом із вами — крок за кроком, звичка за звичкою, день за днем."
          }
        }
      }
    },
