    "Track progress across each week, with one dot per week in the year view.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track progress across each week, with one dot per week in the year view."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledujte pokrok v každém týdnu s jednou tečkou za týden v ročním zobrazení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spor fremskridt på tværs af hver uge med en prik om ugen i årsvisningen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolgen Sie den Fortschritt jede Woche mit einem Punkt pro Woche in der Jahresansicht."
