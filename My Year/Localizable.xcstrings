    "Habits rarely begin on January 1st. Your 365 gives each daily habit its own year, starting on day one." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Návyky málokdy začínají 1. ledna. Tvých 365 dá každému dennímu návyku vlastní rok od prvního dne."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaner starter sjældent 1. januar. Din 365 giver hver daglig vane sit eget år, fra dag ét."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gewohnheiten beginnen selten am 1. Januar. Dein 365 gibt jeder täglichen Gewohnheit ein eigenes Jahr, ab Tag 1."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los hábitos casi nunca empiezan el 1 de enero. Tu 365 da a cada hábito diario su propio año, desde el primer día."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los hábitos rara vez empiezan el 1 de enero. Tu 365 le da a cada hábito diario su propio año, desde el día uno."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Harjumused algavad harva 1. jaanuaril. „Sinu 365” annab igale igapäevasele harjumusele oma aasta, mis algab esimesest päevast."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tavat alkavat harvoin tammikuun ensimmäisenä. Oma 365 antaa jokaiselle päivittäiselle tavalle oman vuoden, joka alkaa ensimmäisestä päivästä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les habitudes commencent rarement le 1er janvier. Ton 365 donne à chaque habitude quotidienne sa propre année, dès le premier jour."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Navike rijetko počinju 1. siječnja. Tvojih 365 svakoj dnevnoj navici daje vlastitu godinu, od prvog dana."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A szokások ritkán kezdődnek január 1-jén. A Saját 365 minden napi szokásnak saját évet ad, az első naptól."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le abitudini raramente iniziano il primo gennaio. Il tuo 365 dà a ogni abitudine quotidiana il suo anno, dal primo giorno."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ieradumi reti sākas 1. janvārī. Your 365 katram ikdienas ieradumam dod savu gadu, sākot no pirmās dienas."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaner starter sjelden 1. januar. Din 365 gir hver daglige vane sitt eget år, fra dag én."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gewoonten beginnen zelden op 1 januari. Jouw 365 geeft elke dagelijkse gewoonte een eigen jaar, vanaf dag één."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nawyki rzadko zaczynają się 1 stycznia. Twoje 365 daje każdemu codziennemu nawykowi własny rok, liczony od dnia 1."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hábitos quase nunca começam em 1º de janeiro. O Seu 365 dá a cada hábito diário um ano próprio, começando no Dia 1."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Obiceiurile rareori încep pe 1 ianuarie. Your 365 îi dă fiecărui obicei zilnic propriul an, începând cu ziua 1."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Návyky málokedy začínajú 1. januára. Tvojich 365 dá každému dennému zvyku vlastný rok od prvého dňa."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Navade se redko začnejo 1. januarja. Tvojih 365 vsaki dnevni navadi da svoje leto, ki se začne prvi dan."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vanor börjar sällan den 1 januari. Your 365 ger varje daglig vana ett eget år, från dag ett."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Звички рідко починаються 1 січня. Your 365 дає кожній щоденній звичці власний рік — з першого дня."
          }
        }
      }
    },
