    "Archiving hides this calendar from your boards without deleting past data.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'archiviazione nasconde questo calendario dalle tue bacheche senza eliminare i dati passati."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Архівування приховує цей календар із ваших дошок, не видаляючи минулі дані."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivar oculta este calendario de tus tableros sin eliminar datos anteriores."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Archivar oculta este calendario de tus tableros sin eliminar datos anteriores."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O arquivamento oculta este calendário dos seus quadros sem excluir os dados anteriores."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch die Archivierung wird dieser Kalender vor Ihren Pinnwänden ausgeblendet, ohne dass frühere Daten gelöscht werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'archivage masque ce calendrier de vos tableaux sans supprimer les données passées."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Door te archiveren verbergt u deze kalender voor uw borden zonder eerdere gegevens te verwijderen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkivering skjuler denne kalender fra dine tavler uden at slette tidligere data."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkivering döljer den här kalendern från dina anslagstavlor utan att radera tidigare data."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkivering skjuler denne kalenderen fra tavlene dine uten å slette tidligere data."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Archiwizacja ukrywa ten kalendarz przed Twoimi tablicami bez usuwania wcześniejszych danych."
          }
        }
      }
    },
    "Are you sure you want to delete '\\(calendar.name)'? This action cannot be undone.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuoi eliminare \"\\(calendar.name)\"? Questa azione non può essere annullata."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви впевнені, що хочете видалити \"\\(calendar.name)\"? Цю дію не можна скасувати."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Está seguro de que desea eliminar '\\(calendar.name)'? Esta acción no se puede deshacer."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Está seguro de que desea eliminar '\\(calendar.name)'? Esta acción no se puede deshacer."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir '\\(calendar.name)'? Esta ação não pode ser desfeita."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie „\\(calendar.name)“ löschen möchten? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Etes-vous sûr de vouloir supprimer «\\(calendar.name)»? Cette action ne peut pas être annulée."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet u zeker dat u '\\(calendar.name)' wilt verwijderen? Deze actie kan niet ongedaan worden gemaakt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Er du sikker på, at du vil slette '\\(calendar.name)'? Denne handling kan ikke fortrydes."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Är du säker på att du vill ta bort '\\(calendar.name)'? Denna åtgärd kan inte ångras."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Er du sikker på at du vil slette '\\(calendar.name)'? Denne handlingen kan ikke angres."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz usunąć „\\(calendar.name)”? Tej akcji nie można cofnąć."
          }
        }
      }
    },
