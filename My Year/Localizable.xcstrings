        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klepnutím na kalendář jej zrušte z archivu a přeneste jej zpět na své nástěnky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryk på en kalender for at fjerne den fra arkivet og bringe den tilbage til dine tavler."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf einen Kalender, um ihn aus dem Archiv zurück auf deine Boards zu holen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca un calendario para desarchivarlo y devolverlo a tus tableros."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca un calendario para desarchivarlo y devolverlo a tus tableros."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puudutage kalendrit, et see arhiivist eemaldada ja oma tahvlitele tagasi tuua."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Napauta kalenteria poistaaksesi sen arkistosta ja tuodaksesi sen takaisin taulullesi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur un calendrier pour le désarchiver et le ramener sur vos tableaux."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
