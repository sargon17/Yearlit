    "My goal is to make Yearlit the most useful tool out there for building consistency — but I can’t do that alone.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il mio obiettivo è rendere Yearlit lo strumento più utile in circolazione per costruire costanza — ma da solo non posso farcela."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Моя мета — зробити Yearlit найкориснішим інструментом для розвитку сталості, але сам я цього не зроблю."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mi objetivo es hacer de Yearlit la herramienta más útil para crear constancia, pero no puedo hacerlo solo."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Mi objetivo es hacer de Yearlit la herramienta más útil para crear constancia, pero no puedo hacerlo solo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Meu objetivo é tornar o Yearlit a ferramenta mais útil para construir consistência, mas não posso fazer isso sozinho."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mein Ziel ist es,Yearlit zum nützlichsten Tool zum Aufbau von Konsistenz zu machen – aber das kann ich nicht alleine schaffen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mon objectif est de faire de Yearlit l'outil le plus utile pour renforcer la cohérence, mais je ne peux pas le faire seul."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Mijn doel is om van Yearlit het nuttigste hulpmiddel te maken dat er is om consistentie op te bouwen, maar dat kan ik niet alleen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit mål er at gøre Yearlit til det mest nyttige værktøj derude til at opbygge konsistens - men jeg kan ikke gøre det alene."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mitt mål är att göra Yearlit till det mest användbara verktyget för att bygga konsistens – men jag kan inte göra det ensam."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Målet mitt er å gjøre Yearlit til det mest nyttige verktøyet der ute for å bygge konsistens - men jeg kan ikke gjøre det alene."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Moim celem jest uczynienie Yearlit najbardziej użytecznym narzędziem do budowania spójności – ale nie mogę tego zrobić sam."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tavoitteeni on tehdä Yearlit:sta hyödyllisin työkalu johdonmukaisuuden rakentamiseen – mutta en voi tehdä sitä yksin."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Mým cílem je vytvořit z Yearlit nejužitečnější nástroj pro budování konzistence – ale nemohu to udělat sám."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Scopul meu este să fac din Yearlit cel mai util instrument pentru a crea coerență – dar nu pot face asta singur."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az a célom, hogy a Yearlit a leghasznosabb eszköz legyen a következetesség kialakításához – de ezt egyedül nem tudom megtenni."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Mojím cieľom je urobiť z Yearlit najužitočnejší nástroj na budovanie konzistentnosti – ale sám to nedokážem."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Moj cilj je učiniti Yearlit najkorisnijim alatom za izgradnju dosljednosti - ali to ne mogu sam."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Moj cilj je narediti Yearlit najbolj uporabno orodje za ustvarjanje doslednosti – vendar tega ne morem storiti sam."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Minu eesmärk on muuta Yearlit järjepidevuse suurendamiseks kõige kasulikumaks tööriistaks, kuid ma ei saa seda üksi teha."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mans mērķis ir padarīt Yearlit par visnoderīgāko rīku konsekvences veidošanai, taču es to nevaru paveikt viens."
          }
        }
      }
    },
