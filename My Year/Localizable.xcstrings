          "stringUnit": {
            "state": "translated",
            "value": "Yearlit auttaa sinua todistamaan sen päivä kerrallaan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit vous aidera à le prouver, un jour à la fois."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit će vam pomoći da to dokažete, dan po dan."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az Yearlit segít bizonyítani, egy napról a másikra."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit ti aiuterà a dimostrarlo, un giorno alla volta."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit palīdzēs jums to pierādīt katru dienu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit vil hjelpe deg å bevise det, en dag av gangen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit helpt je dit dag voor dag te bewijzen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit pomoże Ci to udowodnić, każdego dnia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit irá ajudá-lo a provar isso, um dia de cada vez."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit te va ajuta să demonstrezi asta, pe zi."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit vám to pomôže dokázať, jeden deň za druhým."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit vam bo pomagal dokazati, dan za dnem."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit hjälper dig att bevisa det, en dag i taget."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit допоможе вам довести це кожен день."
          }
        }
