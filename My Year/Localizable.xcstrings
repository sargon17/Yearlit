        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pouze odznak a zvuk, na obrazovce uzamčení není vidět žádný text"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
