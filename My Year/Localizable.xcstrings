    "Track a simple yes/no each day. Great for habits you either complete or skip." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Každý den sleduj jednoduché ano/ne. Hodí se pro návyky, které buď splníš, nebo vynecháš."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spor et simpelt ja/nej hver dag. Fantastisk til vaner, du enten gennemfører eller springer over."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trage jeden Tag ein einfaches Ja/Nein ein. Gut für Gewohnheiten, die du entweder erledigst oder auslässt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Track a simple yes/no each day. Great for habits you either complete or skip."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Realice un seguimiento de un simple sí o no cada día. Ideal para hábitos que completas o te saltas."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Realice un seguimiento de un simple sí o no cada día. Ideal para hábitos que completas o te saltas."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jälgige iga päev lihtsat jah/ei. Suurepärane harjumuste jaoks, mille te lõpetate või jätate vahele."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seuraa yksinkertaista kyllä/ei joka päivä. Erinomainen tottumuksiin, jotka joko suoritat loppuun tai ohitat."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suivez un simple oui/non chaque jour. Idéal pour les habitudes que vous complétez ou sautez."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prati jednostavno da/ne svaki dan. Odlično za navike koje ili odradiš ili preskočiš."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kövess egy egyszerű igen/nem állapotot minden nap. Olyan szokásokhoz jó, amelyeket vagy teljesítesz, vagy kihagysz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra un semplice sì/no ogni giorno. Ideale per abitudini che completi o salti."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Katru dienu atzīmē vienkāršu jā/nē. Der ieradumiem, kurus vai nu izdari, vai izlaid."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spor et enkelt ja/nei hver dag. Perfekt for vaner du enten gjør eller hopper over."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Houd elke dag een eenvoudig ja/nee bij. Ideaal voor gewoontes die je afmaakt of overslaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Śledź proste tak/nie każdego dnia. Świetne w przypadku nawyków, które albo dokończysz, albo pominiesz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acompanhe um sim/não por dia. Ótimo para hábitos que você cumpre ou pula."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Urmăriți un simplu da/nu în fiecare zi. Excelent pentru obiceiurile pe care fie le completați, fie le omiteți."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sleduj jednoduché áno/nie každý deň. Ideálne pre zvyky, ktoré buď splníš, alebo vynecháš."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vsak dan spremljaj preprost da/ne. Dobro za navade, ki jih opraviš ali preskočiš."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Följ ett enkelt ja eller nej varje dag. Passar vanor du antingen gör eller hoppar över."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відмічай просте так/ні щодня. Чудово для звичок, які або виконуються, або ні."
          }
        }
      }
    },
    "Track a simple yes/no each week. Great for goals you either hit or miss across the week." : {
