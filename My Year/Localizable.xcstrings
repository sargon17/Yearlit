    "Create your first stack to chain habits together.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea il tuo primo stack per collegare le abitudini tra loro."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Створіть перший стек, щоб поєднати звички в ланцюжок."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea tu primera pila para encadenar hábitos."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea tu primera pila para encadenar hábitos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie sua primeira pilha para encadear hábitos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstellen Sie Ihren ersten Stapel, um Gewohnheiten miteinander zu verknüpfen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez votre première pile pour enchaîner les habitudes."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Creëer je eerste stapel om gewoonten aan elkaar te koppelen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Opret din første stak for at kæde vaner sammen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skapa din första stack för att kedja vanor tillsammans."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lag din første stabel for å lenke vaner sammen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Utwórz swój pierwszy stos, aby połączyć nawyki."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Luo ensimmäinen pinosi ketjuttaaksesi tottumukset yhteen."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vytvořte svůj první hromádku, abyste spojili návyky."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Creați-vă primul stivă pentru a lega obiceiurile împreună."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hozd létre az első köteget a szokások összekapcsolásához."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vytvorte si svoj prvý zásobník na reťazenie návykov."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Stvorite svoju prvu hrpu kako biste spojili navike."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ustvarite svoj prvi kup, da povežete navade."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Looge oma esimene virn, et harjumusi omavahel ühendada."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Izveidojiet savu pirmo kaudzi, lai apvienotu ieradumus."
          }
        },
