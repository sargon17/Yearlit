        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az igazság? Sosem voltam természetesen következetes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La verità? Non sono mai stato naturalmente costante."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patiesība? Es nekad neesmu bijis dabiski konsekvents."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sannheten? Jeg har aldri vært naturlig jevn."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De waarheid? Ik ben nooit van nature consistent geweest."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prawda? Nigdy nie byłam z natury konsekwentna."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A verdade? Consistência nunca veio naturalmente para mim."
