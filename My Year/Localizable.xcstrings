    "You did it last week, you can do it this week! 💚": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo hai fatto la scorsa settimana, puoi farlo questa settimana! 💚"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви зробили це минулого тижня, ви можете зробити це цього тижня! 💚"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Lo hiciste la semana pasada, puedes hacerlo esta semana! 💚"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Lo hiciste la semana pasada, puedes hacerlo esta semana! 💚"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você fez isso na semana passada, você pode fazer isso esta semana! 💚"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast es letzte Woche geschafft, du schaffst es diese Woche! 💚"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous l'avez fait la semaine dernière, vous pouvez le faire cette semaine! 💚"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je deed het vorige week, je kunt het deze week doen! 💚"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du gjorde det i sidste uge, du kan gøre det i denne uge! 💚"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du gjorde det förra veckan, du kan göra det den här veckan! 💚"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du gjorde det forrige uke, du kan gjøre det denne uken! 💚"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zrobiłeś to w zeszłym tygodniu, możesz to zrobić w tym tygodniu! 💚"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Teit sen viime viikolla, voit tehdä sen tällä viikolla! 💚"
