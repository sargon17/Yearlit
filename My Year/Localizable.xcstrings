    "Great job last week! Let's keep it going this week 🎯": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ottimo lavoro la settimana scorsa! Continuiamo così questa settimana 🎯"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Чудова робота минулого тижня! Продовжимо так і цього тижня 🎯"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Buen trabajo la semana pasada! Sigamos así esta semana 🎯"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Buen trabajo la semana pasada! Sigamos así esta semana 🎯"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ótimo trabalho na semana passada! Vamos continuar essa semana 🎯"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tolle Arbeit letzte Woche! Lasst uns diese Woche weitermachen 🎯"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Super boulot la semaine dernière! Continuons cette semaine 🎯"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Super gedaan afgelopen week! Laten we het deze week volhouden 🎯"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Godt arbejde i sidste uge! Lad os fortsætte i denne uge 🎯"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bra jobbat förra veckan! Låt oss fortsätta den här veckan 🎯"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bra jobbet forrige uke! La oss fortsette med det denne uken 🎯"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Świetna robota w zeszłym tygodniu! Kontynuujmy to w tym tygodniu 🎯"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hienoa työtä viime viikolla! Jatketaan tällä viikolla 🎯"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Skvělá práce minulý týden! Pojďme v tom pokračovat i tento týden 🎯"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Mare treabă săptămâna trecută! Să continuăm săptămâna aceasta 🎯"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nagyszerű munka múlt héten! Folytassuk a héten 🎯"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Skvelá práca minulý týždeň! Pokračujme v tom aj tento týždeň 🎯"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odličan posao prošli tjedan! Nastavimo tako i ovaj tjedan 🎯"
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odlično delo prejšnji teden! Nadaljujmo ta teden 🎯"
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Suurepärane töö eelmisel nädalal! Jätkame sel nädalal 🎯"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lielisks darbs pagājušajā nedēļā! Tā turpināsim šonedēļ 🎯"
          }
        }
      }
    },
