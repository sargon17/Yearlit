    "Don’t keep it to yourself. The fastest way to make this app better for you is to tell me what’s on your mind." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nenechávejte si to pro sebe. Nejrychlejší způsob, jak pro vás tuto aplikaci vylepšit, je říct mi, co máte na mysli."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hold det ikke for dig selv. Den hurtigste måde at gøre denne app bedre for dig er at fortælle mig, hvad du tænker på."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Behalte es nicht für dich. Der schnellste Weg, diese App für dich besser zu machen: Sag mir, was dir auffällt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No te lo guardes para ti. La forma más rápida de mejorar esta aplicación para ti es decirme qué tienes en mente."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No te lo guardes para ti. La forma más rápida de mejorar esta aplicación para ti es decirme qué tienes en mente."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ärge hoidke seda enda teada. Kiireim viis selle rakenduse paremaks muutmiseks on öelda mulle, mis teil meeles on."
