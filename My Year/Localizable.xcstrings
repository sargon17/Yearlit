    "No empty months. No feeling late. Just the year you’re actually building." : {
      "comment" : "A description of the \"Your 365\" feature, emphasizing the sense of accomplishment and purpose that comes with building a year one day at a time.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Žádné prázdné měsíce. Žádný pocit, že jdeš pozdě. Jen rok, který opravdu buduješ."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen tomme måneder. Ingen følelse af at være bagud. Kun det år, du faktisk bygger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keine leeren Monate. Kein Gefühl, zu spät zu sein. Nur das Jahr, das du wirklich aufbaust."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sin meses vacíos. Sin sentir que llegas tarde. Solo el año que estás construyendo de verdad."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sin meses vacíos. Sin sentir que vas tarde. Solo el año que estás construyendo de verdad."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ei tühje kuid. Ei tunnet, et oled hiljaks jäänud. Ainult aasta, mida sa päriselt ehitad."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ei tyhjiä kuukausia. Ei tunnetta, että olet myöhässä. Vain vuosi, jota oikeasti rakennat."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pas de mois vides. Pas l’impression d’être en retard. Juste l’année que tu construis vraiment."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nema praznih mjeseci. Nema osjećaja da kasniš. Samo godina koju stvarno gradiš."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nincsenek üres hónapok. Nincs késésérzet. Csak az az év, amit tényleg építesz."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Niente mesi vuoti. Niente sensazione di essere in ritardo. Solo l'anno che stai costruendo davvero."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bez tukšiem mēnešiem. Bez sajūtas, ka esi nokavējis. Tikai gads, kuru tu tiešām veido."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen tomme måneder. Ingen følelse av å ligge etter. Bare året du faktisk bygger."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geen lege maanden. Geen gevoel dat je te laat bent. Alleen het jaar dat je echt aan het bouwen bent."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bez pustych miesięcy. Bez poczucia, że jesteś spóźniony. Tylko rok, który naprawdę budujesz."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sem meses vazios. Sem sensação de atraso. Só o ano que você está construindo de verdade."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fără luni goale. Fără senzația că ai întârziat. Doar anul pe care îl construiești cu adevărat."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Žiadne prázdne mesiace. Žiadny pocit, že meškáš. Len rok, ktorý naozaj buduješ."
          }
        },
        "sl" : {
