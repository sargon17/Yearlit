        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås upp djupare statistik, widgets och mer utrymme för att spåra ditt år."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås opp dypere statistikk, widgets og mer plass for å spore året."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odblokuj głębsze statystyki, widżety i więcej miejsca na śledzenie roku."
          }
        },
        "fi": {
          "stringUnit": {
