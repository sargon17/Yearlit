            "value": "Ne vous contentez pas de vous fixer des objectifs"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stel niet alleen doelen"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sæt ikke kun mål"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sätt inte bara upp mål"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikke bare sett deg mål"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie wyznaczaj tylko celów"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Älä aseta vain tavoitteita"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nedávejte si jen cíle"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu vă fixați doar obiective"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne csak célokat tűzz ki"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nedávajte si len ciele"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nemojte samo postavljati ciljeve"
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne postavljajte si samo ciljev"
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Ärge seadke ainult eesmärke"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Neizvirziet tikai mērķus"
          }
        }
      }
