            "value": "Faceți upgrade la Premium pentru a adăuga mai multe ori."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Frissítsen Premiumra, hogy több alkalommal is hozzáadhasson."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ak chcete pridať viackrát, inovujte na Premium."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nadogradite na Premium da biste dodali više puta."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nadgradite na Premium, če želite dodati več."
          }
        },
