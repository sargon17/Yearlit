    "At 9 PM, if your streak is at risk, we send one extra reminder.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle 21:00, se la tua serie è a rischio, inviamo un promemoria extra."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "О 21:00, якщо серія під загрозою, ми надішлемо додаткове нагадування."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A las 9 p.m., si tu racha está en riesgo, te enviamos un recordatorio adicional."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "A las 9 p.m., si tu racha está en riesgo, te enviamos un recordatorio adicional."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Às 21h, se sua sequência estiver em risco, enviamos um lembrete extra."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Ihr Streak gefährdet ist, senden wir um 21:00 Uhr eine zusätzliche Erinnerung."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À 21 heures, si votre séquence est à risque, nous envoyons un rappel supplémentaire."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als uw streak in gevaar is, sturen we om 21.00 uur een extra herinnering."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "21.00, hvis din streak er i fare, sender vi en ekstra påmindelse."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Klockan 21.00, om din streak är i riskzonen, skickar vi en extra påminnelse."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Klokken 21.00, hvis rekken din er i fare, sender vi én ekstra påminnelse."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli Twoja passa jest zagrożona, o 21:00 wyślemy dodatkowe przypomnienie."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Klo 21.00, jos sarjasi on vaarassa, lähetämme yhden ylimääräisen muistutuksen."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve 21:00, pokud je vaše série ohrožena, zašleme jednu další připomínku."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "La ora 21:00, dacă întâmpinarea dvs. este în pericol, vă trimitem un memento suplimentar."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Este 21 órakor, ha a sorozatod veszélyben van, küldünk egy extra emlékeztetőt."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ak je vaša séria ohrozená, o 21:00 vám pošleme jednu pripomienku navyše."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "U 21 sat, ako je vaš niz ugrožen, šaljemo jedan dodatni podsjetnik."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ob 21. uri, če je vaš niz ogrožen, pošljemo en dodatni opomnik."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kell 21.00, kui teie seeria on ohus, saadame ühe lisameeldetuletuse."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "21:00, ja jūsu sērija ir apdraudēta, mēs nosūtām vienu papildu atgādinājumu."
          }
        }
      }
    },
