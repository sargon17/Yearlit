          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przejdź na wersję Premium, aby dodać więcej razy."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Päivitä Premiumiin, niin voit lisätä lisää kertoja."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Upgradujte na Premium a přidejte vícekrát."
          }
        },
