          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez les progrès chaque semaine, avec un point par semaine dans la vue annuelle."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pratite napredak kroz svaki tjedan, s jednom točkom po tjednu u prikazu godine."
