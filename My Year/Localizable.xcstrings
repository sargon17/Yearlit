        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium message templates render one optional line, up to 40 characters."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I modelli Premium con messaggio mostrano una riga opzionale, fino a 40 caratteri."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Преміум-шаблони з повідомленням показують один необов’язковий рядок до 40 символів."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las plantillas Premium con mensaje muestran una línea opcional de hasta 40 caracteres."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Las plantillas Premium con mensaje muestran una línea opcional de hasta 40 caracteres."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os modelos Premium com mensagem mostram uma linha opcional de até 40 caracteres."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium-Vorlagen mit Nachricht zeigen eine optionale Zeile mit bis zu 40 Zeichen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les modèles Premium avec message affichent une ligne facultative de 40 caractères maximum."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium berichtsjablonen tonen één optionele regel van maximaal 40 tekens."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium-skabeloner med besked viser én valgfri linje på op til 40 tegn."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium-mallar med meddelande visar en valfri rad på upp till 40 tecken."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium-maler med melding viser én valgfri linje på opptil 40 tegn."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Szablony Premium z wiadomością pokazują jeden opcjonalny wiersz do 40 znaków."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium-viestimallit näyttävät yhden valinnaisen rivin, enintään 40 merkkiä."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Prémiové šablony se zprávou zobrazí jeden volitelný řádek do 40 znaků."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Șabloanele Premium cu mesaj afișează o linie opțională, de până la 40 de caractere."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A prémium üzenetes sablonok egy opcionális, legfeljebb 40 karakteres sort jelenítenek meg."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Prémiové šablóny so správou zobrazia jeden voliteľný riadok do 40 znakov."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium predlošci s porukom prikazuju jedan neobavezni redak do 40 znakova."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium predloge s sporočilom prikažejo eno izbirno vrstico do 40 znakov."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium-sõnumimallid kuvavad ühe valikulise rea kuni 40 märgiga."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium ziņojumu veidnes rāda vienu neobligātu rindu līdz 40 rakstzīmēm."
          }
        }
      }
    },
