    "Each habit starts its own 365-day journey from the day you began.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each habit starts its own 365-day journey from the day you began."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Každý návyk začíná svou vlastní 365denní cestu ode dne, kdy jste začali."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hver vane starter sin egen 365-dages rejse fra den dag, du begyndte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Gewohnheit beginnt ihre eigene 365-Tage-Reise ab dem Tag, an dem Sie begonnen haben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada hábito comienza su propio viaje de 365 días desde el día en que comenzó."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada hábito comienza su propio viaje de 365 días desde el día en que comenzó."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Iga harjumus alustab oma 365-päevast teekonda päevast, mil te alustasite."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jokainen tapa aloittaa oman 365 päivän matkansa päivästä, jolloin aloitit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque habitude commence son propre voyage de 365 jours à partir du jour où vous avez commencé."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Svaka navika započinje svoje vlastito putovanje od 365 dana od dana kada ste počeli."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Minden szokás elkezdi a saját 365 napos útját attól a naptól kezdve, amikor elkezdted."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni abitudine inizia il proprio viaggio di 365 giorni dal giorno in cui hai iniziato."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Katrs ieradums sāk savu 365 dienu ceļojumu no dienas, kad sākāt."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hver vane starter sin egen 365-dagers reise fra dagen du begynte."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Elke gewoonte begint zijn eigen reis van 365 dagen vanaf de dag waarop je ermee begon."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Każdy nawyk rozpoczyna swoją własną 365-dniową podróż od dnia, w którym zacząłeś."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada hábito inicia sua própria jornada de 365 dias a partir do dia em que você começou."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fiecare obicei își începe propria călătorie de 365 de zile din ziua în care ați început."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Každý zvyk začína svoju vlastnú 365-dňovú cestu odo dňa, keď ste začali."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vsaka navada začne svojo 365-dnevno pot od dneva, ko ste jo začeli."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Varje vana börjar sin egen 365-dagars resa från dagen du började."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Кожна звичка починає свій власний 365-денний шлях з того дня, як ви почали."
          }
        }
      }
    },
    "View progress from January to December.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "View progress from January to December."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zobrazit průběh od ledna do prosince."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Se fremskridt fra januar til december."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sehen Sie sich den Fortschritt von Januar bis Dezember an."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ver el progreso de enero a diciembre."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Ver el progreso de enero a diciembre."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaadake edenemist jaanuarist detsembrini."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarkastele edistymistä tammikuusta joulukuuhun."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualisez les progrès de janvier à décembre."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pogledajte napredak od siječnja do prosinca."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A január és december közötti előrehaladás megtekintése."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Visualizza i progressi da gennaio a dicembre."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skatiet progresu no janvāra līdz decembrim."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Se fremdriften fra januar til desember."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bekijk de voortgang van januari tot december."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zobacz postęp od stycznia do grudnia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja o progresso de janeiro a dezembro."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Vedeți progresul din ianuarie până în decembrie."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pozrite si priebeh od januára do decembra."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Oglejte si napredek od januarja do decembra."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Se framstegen från januari till december."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перегляньте прогрес із січня по грудень."
          }
        }
      }
    },
    "Your 365 starts each daily habit from the day you began. Calendar Year shows January to December progress.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your 365 starts each daily habit from the day you began. Calendar Year shows January to December progress."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše 365 začíná každý denní návyk ode dne, kdy jste začali. Kalendářní rok ukazuje průběh od ledna do prosince."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din 365 starter hver daglige vane fra den dag, du startede. Kalenderår viser fremskridt fra januar til december."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr 365 beginnt mit jeder täglichen Gewohnheit vom Tag an, an dem Sie begonnen haben. Das Kalenderjahr zeigt den Fortschritt von Januar bis Dezember."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu 365 comienza cada hábito diario desde el día en que empezaste. El año calendario muestra el progreso de enero a diciembre."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu 365 comienza cada hábito diario desde el día en que empezaste. El año calendario muestra el progreso de enero a diciembre."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Teie 365 alustab iga igapäevast harjumust päevast, mil alustasite. Kalendriaasta näitab edenemist jaanuarist detsembrini."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "365 aloittaa jokaisen päivittäisen tottumuksen aloituspäivästä lähtien. Kalenterivuosi näyttää edistymisen tammi-joulukuussa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre 365 démarre chaque habitude quotidienne à partir du jour où vous avez commencé. L'année civile montre les progrès de janvier à décembre."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaših 365 počinje svaka dnevna navika od dana kada ste počeli. Kalendarska godina pokazuje napredak od siječnja do prosinca."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A 365-ösöd minden napi szokásod attól a naptól kezdődik, amikor elkezdted. A naptári év a januártól decemberig tartó előrehaladást mutatja."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo 365 inizia ogni abitudine quotidiana dal giorno in cui hai iniziato. L'anno solare mostra l'avanzamento da gennaio a dicembre."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jūsu 365 sāk katru ikdienas ieradumu no dienas, kad sākāt. Kalendāra gads parāda progresu no janvāra līdz decembrim."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Din 365 starter hver daglige vane fra dagen du begynte. Kalenderår viser fremgang fra januar til desember."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je 365 start elke dagelijkse gewoonte vanaf de dag waarop je ermee begon. Kalenderjaar toont de voortgang van januari tot en met december."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje 365 rozpoczyna każdy codzienny nawyk od dnia, w którym zacząłeś. Rok kalendarzowy pokazuje postęp od stycznia do grudnia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu 365 inicia cada hábito diário desde o dia em que você começou. O ano civil mostra o progresso de janeiro a dezembro."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "365 dvs. începe fiecare obicei zilnic din ziua în care ați început. Anul calendaristic arată progresul din ianuarie până în decembrie."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš 365 začína každý denný návyk odo dňa, keď ste začali. Kalendárny rok zobrazuje priebeh od januára do decembra."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaš 365 začne vsako dnevno navado od dne, ko ste začeli. Koledarsko leto prikazuje napredek od januarja do decembra."
          }
        },
        "sv": {
          "stringUnit": {
