    "My goal is to make Yearlit the most useful tool out there for building consistency — but I can’t do that alone." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chci, aby byl Yearlit co nejužitečnější nástroj pro budování pravidelnosti. Sám to ale nezvládnu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit mål er at gøre Yearlit til det mest nyttige værktøj derude til at opbygge konsistens - men jeg kan ikke gøre det alene."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mein Ziel ist, Yearlit zum nützlichsten Werkzeug für Beständigkeit zu machen - aber allein schaffe ich das nicht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mi objetivo es hacer de Yearlit la herramienta más útil para crear constancia, pero no puedo hacerlo solo."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mi objetivo es hacer de Yearlit la herramienta más útil para crear constancia, pero no puedo hacerlo solo."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minu eesmärk on muuta Yearlit järjepidevuse suurendamiseks kõige kasulikumaks tööriistaks, kuid ma ei saa seda üksi teha."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tavoitteeni on tehdä Yearlit:sta hyödyllisin työkalu johdonmukaisuuden rakentamiseen – mutta en voi tehdä sitä yksin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mon objectif est de faire de Yearlit l'outil le plus utile pour renforcer la cohérence, mais je ne peux pas le faire seul."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Moj je cilj da Yearlit postane najkorisniji alat za izgradnju dosljednosti — ali to ne mogu sam."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az a célom, hogy a Yearlit a leghasznosabb eszköz legyen a következetesség kialakításához – de ezt egyedül nem tudom megtenni."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il mio obiettivo è rendere Yearlit lo strumento più utile in circolazione per costruire costanza — ma da solo non posso farcela."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mans mērķis ir padarīt Yearlit par visnoderīgāko rīku konsekvences veidošanai, taču es to nevaru paveikt viens."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Målet mitt er å gjøre Yearlit til det mest nyttige verktøyet for å bygge jevn rytme, men jeg kan ikke gjøre det alene."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mijn doel is om van Yearlit het nuttigste hulpmiddel te maken dat er is om consistentie op te bouwen, maar dat kan ik niet alleen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chcę, żeby Yearlit było najbardziej użytecznym narzędziem do budowania konsekwencji — ale nie zrobię tego sam."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meu objetivo é fazer do Yearlit a ferramenta mais útil para criar consistência, mas não consigo fazer isso sozinho."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Scopul meu este să fac din Yearlit cel mai util instrument pentru consecvență — dar nu pot face asta singur."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chcem, aby bol Yearlit čo najužitočnejší nástroj na budovanie pravidelnosti. Sám to však nezvládnem."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Moj cilj je, da Yearlit postane najbolj uporabno orodje za gradnjo doslednosti. Tega pa ne morem narediti sam."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitt mål är att göra Yearlit till det mest användbara verktyget för att bygga kontinuitet, men jag kan inte göra det ensam."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Моя мета — зробити Yearlit найкориснішим інструментом для розвитку сталості, але сам я цього не зроблю."
          }
        }
      }
    },
