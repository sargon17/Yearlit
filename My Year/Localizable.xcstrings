    "Your year starts the day you do.": {
      "comment": "A description of how the \"Your 365\" timeline works.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo anno inizia il giorno in cui inizi tu."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Твій рік починається в день, коли починаєш ти."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu año comienza el día que tú lo haces."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu año comienza el día que tú lo haces."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu ano começa no dia em que você faz isso."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr Jahr beginnt an dem Tag, an dem Sie es tun."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre année commence le jour où vous le faites."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jouw jaar begint op de dag dat jij dat doet."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit år starter den dag, du gør."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ditt år börjar samma dag som du gör det."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Året ditt starter den dagen du gjør det."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twój rok zaczyna się w dniu, w którym to robisz."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuodesi alkaa siitä päivästä, jolloin aloitat."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš rok začíná dnem, kdy to uděláte."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Anul tău începe în ziua în care o faci."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az éved azon a napon kezdődik, amikor elkezded."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš rok sa začína dňom, keď to robíte."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša godina počinje onog dana kada počnete."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše leto se začne z dnem, ko ga naredite."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Teie aasta algab päevast, mil te seda teete."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jūsu gads sākas dienā, kad to darāt."
