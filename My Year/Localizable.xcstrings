            "value": "Un pequeño paso es suficiente para reiniciar."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Un pequeño paso es suficiente para reiniciar."
          }
        },
        "pt-BR": {
