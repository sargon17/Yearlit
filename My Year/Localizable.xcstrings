    "Habits rarely begin on January 1st. Your 365 gives each daily habit its own year, starting on day one.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le abitudini iniziano raramente il 1° gennaio. Il tuo 365 dà a ogni abitudine quotidiana il suo anno, a partire dal primo giorno."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Звички рідко починаються 1 січня. Твій 365 дає кожній щоденній звичці власний рік, починаючи з першого дня."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los hábitos rara vez comienzan el 1 de enero. Tu 365 le da a cada hábito diario su propio año, comenzando desde el primer día."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Los hábitos rara vez comienzan el 1 de enero. Tu 365 le da a cada hábito diario su propio año, comenzando desde el primer día."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os hábitos raramente começam em 1º de janeiro. Seu 365 dá a cada hábito diário seu próprio ano, começando no primeiro dia."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gewohnheiten beginnen selten am 1. Januar. Ihr 365 gibt jeder täglichen Gewohnheit ein eigenes Jahr, beginnend mit dem ersten Tag."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les habitudes commencent rarement le 1er janvier. Votre 365 donne à chaque habitude quotidienne sa propre année, dès le premier jour."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gewoonten beginnen zelden op 1 januari. Jouw 365 geeft elke dagelijkse gewoonte een eigen jaar, beginnend op de eerste dag."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaner begynder sjældent den 1. januar. Din 365 giver hver daglig vane sit eget år, startende på dag ét."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vanor börjar sällan den 1 januari. Din 365 ger varje daglig vana sitt eget år, med början på dag ett."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaner begynner sjelden 1. januar. Din 365 gir hver daglig vane sitt eget år, fra dag én."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nawyki rzadko zaczynają się 1 stycznia. Twoje 365 nadaje każdemu codziennemu nawykowi własny rok, zaczynając od pierwszego dnia."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tottumukset alkavat harvoin tammikuun 1. päivänä. 365 antaa jokaiselle päivittäiselle tavalle oman vuoden ensimmäisestä päivästä alkaen."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Návyky zřídka začínají 1. ledna. Vaše 365 dává každému dennímu zvyku jeho vlastní rok, počínaje prvním dnem."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Obiceiurile încep rareori la 1 ianuarie. 365 oferă fiecărui obicei zilnic propriul an, începând din prima zi."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A szokások ritkán kezdődnek január 1-jén. A 365 minden napi szokásnak saját évet ad, az első naptól kezdve."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Návyky zriedka začínajú 1. januára. Vaša 365-ka dáva každému dennému zvyku vlastný rok, počnúc prvým dňom."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Navike rijetko počinju 1. siječnja. Vaših 365 daje svakoj dnevnoj navici vlastitu godinu, počevši od prvog dana."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Navade se le redko začnejo 1. januarja. Vaš 365 daje vsaki dnevni navadi svoje leto, začenši s prvim dnem."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Harjumused saavad harva alguse 1. jaanuaril. Teie 365 annab igale igapäevasele harjumusele oma aasta, alates esimesest päevast."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ieradumi reti sākas 1. janvārī. Jūsu 365 katram ikdienas ieradumam piešķir savu gadu, sākot ar pirmo dienu."
          }
        }
      }
    },
