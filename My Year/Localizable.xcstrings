    "If this helps you keep a promise to yourself, your review helps me keep building it.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If this helps you keep a promise to yourself, your review helps me keep building it."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokud vám to pomůže dodržet slib sobě samému, vaše recenze mi pomůže v jeho budování pokračovat."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis dette hjælper dig med at holde et løfte til dig selv, hjælper din anmeldelse mig med at blive ved med at bygge det."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Ihnen dies hilft, ein Versprechen an sich selbst zu halten, hilft mir Ihre Bewertung, es weiter auszubauen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si esto te ayuda a cumplir una promesa que te has hecho a ti mismo, tu reseña me ayuda a seguir construyéndola."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Si esto te ayuda a cumplir una promesa que te has hecho a ti mismo, tu reseña me ayuda a seguir construyéndola."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kui see aitab teil endale antud lubadust pidada, aitab teie ülevaade mul seda jätkata."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jos tämä auttaa sinua pitämään itsellesi antamasi lupauksen, arvostelusi auttaa minua jatkamaan sen rakentamista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si cela vous aide à tenir une promesse, votre avis m'aide à continuer à la construire."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ako vam ovo pomaže da održite obećanje koje ste dali sebi, vaša recenzija pomaže meni da ga nastavim graditi."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ha ez segít abban, hogy betartsd egy magadnak tett ígéretet, akkor a véleményed segít tovább építeni azt."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se questo ti aiuta a mantenere una promessa fatta a te stesso, la tua recensione mi aiuta a continuare a costruirla."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ja tas palīdz jums turēt sev doto solījumu, jūsu atsauksme palīdz man to turpināt."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvis dette hjelper deg å holde et løfte til deg selv, hjelper anmeldelsen din meg å fortsette å bygge den."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als dit je helpt een belofte aan jezelf na te komen, helpt jouw recensie mij om die belofte verder uit te bouwen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli pomoże Ci to dotrzymać danej sobie obietnicy, Twoja recenzja pomoże mi ją dalej budować."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Se isso ajuda você a cumprir uma promessa feita a si mesmo, sua avaliação me ajuda a continuar construindo essa promessa."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dacă acest lucru vă ajută să vă respectați o promisiune, recenzia dvs. mă ajută să o construiesc în continuare."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ak vám to pomôže dodržať sľub pre seba, vaša recenzia mi pomôže pokračovať v jeho budovaní."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Če vam to pomaga, da izpolnite obljubo samemu sebi, mi vaša ocena pomaga, da jo še naprej gradim."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Om detta hjälper dig att hålla ett löfte till dig själv, hjälper din recension mig att fortsätta bygga det."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо це допоможе вам виконати обіцянку перед соб��ю, ваш відгук допоможе мені продовжувати це будувати."
          }
        }
      }
    },
    "No pressure you can always do it later.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No pressure you can always do it later."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Žádný nátlak, můžete to udělat později."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Intet pres, du kan altid gøre det senere."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Druck, Sie können es jederzeit später tun."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin presión, siempre puedes hacerlo más tarde."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin presión, siempre puedes hacerlo más tarde."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Pole survet, saate seda alati hiljem teha."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ei paineita, voit aina tehdä sen myöhemmin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas de pression, vous pouvez toujours le faire plus tard."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez pritiska, uvijek možete to učiniti kasnije."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincs nyomás, később bármikor megteheti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessuna pressione, puoi sempre farlo più tardi."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez spiediena jūs vienmēr varat to izdarīt vēlāk."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikke noe press, du kan alltid gjøre det senere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen druk, je kunt het altijd later doen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez presji, zawsze możesz to zrobić później."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem pressão, você sempre pode fazer isso mais tarde."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fără presiune, o puteți face oricând mai târziu."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Žiadny tlak, vždy to môžete urobiť neskôr."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brez pritiska, vedno lahko to storite pozneje."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen press, du kan alltid göra det senare."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Без тиску, ви завжди можете зробити це пізніше."
          }
        }
      }
    },
