          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spor et simpelt ja/nej hver uge. Fantastisk til mål, du enten rammer eller går glip af i løbet af ugen."
          }
        },
        "de" : {
          "stringUnit" : {
