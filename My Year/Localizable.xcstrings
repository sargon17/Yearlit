            "value": "Nem azért hoztam létre ezt az alkalmazást, mert elsajátítottam a problémát."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Túto aplikáciu som nevytvoril, pretože som problém zvládol."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nisam napravio ovu aplikaciju jer sam savladao problem."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Te aplikacije nisem ustvaril, ker sem obvladal težavo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Ma ei loonud seda rakendust, sest sain probleemist aru."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Es neizveidoju šo lietotni, jo apzinājos problēmu."
          }
        }
      }
    },
    "I’d start things with energy and optimism… only to fade when the spark wore off.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniziavo le cose con energia e ottimismo… per poi spegnermi quando la scintilla svaniva."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Я починав із енергією та оптимізмом… а потім згасав, коли іскра зникала."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empezaría las cosas con energía y optimismo... sólo para desvanecerme cuando la chispa se apagara."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Empezaría las cosas con energía y optimismo... sólo para desvanecerme cuando la chispa se apagara."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Eu começaria as coisas com energia e otimismo... apenas para desaparecer quando a faísca desaparecesse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich würde die Dinge mit Energie und Optimismus beginnen … nur um dann zu vergehen, wenn der Funke erloschen ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je commençais les choses avec énergie et optimisme… pour ensuite disparaître lorsque l’étincelle s’est dissipée."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ik begon dingen met energie en optimisme... om vervolgens te vervagen toen de vonk uitdoofde."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg ville starte tingene med energi og optimisme... kun for at falme, når gnisten forsvandt."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jag skulle börja saker med energi och optimism... bara för att blekna när gnistan försvann."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg ville starte ting med energi og optimisme... bare for å blekne når gnisten forsvant."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zacząłbym wszystko z energią i optymizmem… tylko po to, by zgasnąć, gdy iskra opadła."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Aloittaisin asiat energisesti ja optimismin... vain haihtumaan, kun kipinä loppui."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Začal bych věci s energií a optimismem... jen abych vybledl, když jiskra vyprchala."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aș începe lucrurile cu energie și optimism... doar ca să se estompeze când scânteia se stingea."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Energiával és optimizmussal kezdeném a dolgokat… csak hogy elhalványuljak, amikor a szikra kialudt."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Začal by som veci s energiou a optimizmom... len aby som vybledol, keď iskra vyprchala."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Započinjao bih stvari s energijom i optimizmom... samo da bi izblijedio kad bi iskra nestala."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stvari bi začel z energijo in optimizmom... le da bi zbledel, ko je iskrica popustila."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Ma alustaksin asju energia ja optimismiga... ainult siis, et tuhmuda, kui säde kustunud."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Es sāktu lietas ar enerģiju un optimismu… tikai lai izgaist, kad dzirkstele nomira."
          }
        }
      }
    },
    "I’m the person behind Yearlit — designer, builder, and fellow struggler when it comes to staying consistent.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sono la persona dietro Yearlit — designer, sviluppatore e compagno di lotta quando si tratta di restare costante."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Я людина за Yearlit — дизайнер, розробник і такий самий борець за сталість."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Soy la persona detrás de Yearlit: diseñador, creador y alguien que también lucha por mantenerse constante."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Soy la persona detrás de Yearlit: diseñador, creador y alguien que también lucha por mantenerse constante."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sou a pessoa por trás do Yearlit: designer, criador e alguém que também luta para manter a consistência."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich bin die Person hinter Yearlit– Designer, Baumeister und Mitstreiter, wenn es darum geht, konsequent zu bleiben."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je suis la personne derrière Yearlit– concepteur, constructeur et compagnon de lutte lorsqu'il s'agit de rester cohérent."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ik ben de persoon achter Yearlit: ontwerper, bouwer en medestrijder als het gaat om consistent blijven."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg er personen bag Yearlit- designer, bygmester og medspiller, når det kommer til at forblive konsekvent."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jag är personen bakom Yearlit— designer, byggare och medkämpar när det gäller att hålla sig konsekvent."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg er personen bak Yearlit– designer, byggmester og andre som sliter når det gjelder å holde seg konsekvent."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To ja stoję za Yearlit— projektantem, konstruktorem i współpracownikiem, który walczy o zachowanie spójności."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Olen Yearlit:n takana oleva henkilö – suunnittelija, rakentaja ja taistelija johdonmukaisuuden suhteen."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jsem osoba, která stojí za Yearlit– návrhář, stavitel a spolubojovník, pokud jde o udržení konzistentnosti."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sunt persoana din spatele Yearlit— designer, constructor și coleg de luptă când vine vorba de a rămâne consecvent."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Én vagyok a Yearlit mögött álló személy – tervező, építő és harcostárs, ha a következetességről van szó."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Som osoba, ktorá stojí za Yearlit– dizajnér, staviteľ a spolubojovník, pokiaľ ide o zachovanie konzistentnosti."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ja sam osoba koja stoji iza Yearlit— dizajner, graditelj i suborac kada treba ostati dosljedan."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jaz sem oseba, ki stoji za Yearlit– oblikovalec, graditelj in soborec, ko je treba ostati dosleden."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Mina olen Yearlit taga – disainer, ehitaja ja järjepidevuse säilitamise kaasvõitleja."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Es esmu persona, kas ir aiz Yearlit— dizainers, celtnieks un līdzstrādnieks, lai saglabātu konsekvenci."
          }
        }
      }
    },
    "I’ve always believed consistency is a kind of superpower.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ho sempre creduto che la costanza sia una sorta di superpotere."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Я завжди вірив, що сталість — це своєрідна суперсила."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Siempre he creído que la coherencia es una especie de superpoder."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Siempre he creído que la coherencia es una especie de superpoder."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sempre acreditei que consistência é uma espécie de superpoder."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich habe immer geglaubt, dass Beständigkeit eine Art Supermacht ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J’ai toujours pensé que la cohérence était une sorte de super pouvoir."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ik heb altijd geloofd dat consistentie een soort superkracht is."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg har altid troet på, at konsistens er en slags superkraft."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jag har alltid trott att konsekvens är en sorts superkraft."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeg har alltid trodd at konsistens er en slags superkraft."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zawsze wierzyłem, że konsekwencja jest rodzajem supermocy."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Olen aina uskonut, että johdonmukaisuus on eräänlainen supervoima."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vždy jsem věřil, že důslednost je druh superschopnosti."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Întotdeauna am crezut că consistența este un fel de superputere."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindig is azt hittem, hogy a következetesség egyfajta szupererő."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vždy som veril, že konzistencia je druh superschopnosti."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uvijek sam vjerovao da je dosljednost neka vrsta supermoći."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vedno sem verjel, da je doslednost neke vrste supermoč."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Olen alati uskunud, et järjepidevus on omamoodi superjõud."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Es vienmēr esmu uzskatījis, ka konsekvence ir sava veida lielvara."
          }
        }
      }
    },
    "Independently engineered. Lovingly crafted.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Progettato in modo indipendente. Realizzato con cura."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Незалежно розроблено. Створено з любов'ю."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Diseñado de forma independiente. Elaborado con amor."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Diseñado de forma independiente. Elaborado con amor."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Projetado de forma independente. Carinhosamente elaborado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unabhängig entwickelt. Liebevoll gefertigt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conçu indépendamment. Fabriqué avec amour."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Onafhankelijk ontwikkeld. Liefdevol gemaakt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Uafhængigt konstrueret. Kærligt udformet."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Självständigt konstruerad. Kärleksfullt utformad."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Selvstendig konstruert. Kjærlig utformet."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niezależnie zaprojektowane. Wykonane z miłością."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Itsenäisesti suunniteltu. Rakkaudella valmistettu."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nezávisle navržený. S láskou vytvořené."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Proiectat independent. Cu dragoste lucrat."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Független tervezésű. Szeretettel kidolgozott."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nezávisle skonštruované. S láskou spracované."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Neovisno projektirano. Izrađeno s ljubavlju."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Neodvisno zasnovan. Izdelano z ljubeznijo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Sõltumatult projekteeritud. Armastusega meisterdatud."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Neatkarīgi izstrādāts. Ar mīlestību veidots."
          }
        }
      }
    },
    "iOS does not let apps open the widget picker directly. Add it from the Home Screen.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS non consente alle app di aprire direttamente il selettore widget. Aggiungilo dalla schermata principale."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS не дозволяє програмам безпосередньо відкривати засіб вибору віджетів. Додайте його з головного екрана."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS no permite que las aplicaciones abran el selector de widgets directamente. Agréguelo desde la pantalla de inicio."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS no permite que las aplicaciones abran el selector de widgets directamente. Agréguelo desde la pantalla de inicio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O iOS não permite que os aplicativos abram o seletor de widgets diretamente. Adicione-o na tela inicial."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS lässt nicht zu, dass Apps die Widget-Auswahl direkt öffnen. Fügen Sie es vom Startbildschirm aus hinzu."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS ne permet pas aux applications d'ouvrir directement le sélecteur de widgets. Ajoutez-le depuis l'écran d'accueil."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS staat niet toe dat apps de widgetkiezer rechtstreeks openen. Voeg het toe vanaf het startscherm."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS tillader ikke apps at åbne widgetvælgeren direkte. Tilføj det fra startskærmen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS låter inte appar öppna widgetväljaren direkt. Lägg till det från startskärmen."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS lar ikke apper åpne widgetvelgeren direkte. Legg den til fra startskjermen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS nie pozwala aplikacjom bezpośrednio otwierać selektora widżetów. Dodaj go z ekranu głównego."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS ei anna sovellusten avata widget-valitsinta suoraan. Lisää se aloitusnäytöstä."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS neumožňuje aplikacím otevřít výběr widgetů přímo. Přidejte jej z domovské obrazovky."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS nu permite aplicațiilor să deschidă direct selectorul de widget-uri. Adăugați-l din ecranul de pornire."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az iOS nem engedi, hogy az alkalmazások közvetlenül nyissa meg a widgetválasztót. Adja hozzá a kezdőképernyőről."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS neumožňuje aplikáciám priamo otvárať výber miniaplikácií. Pridajte ho z domovskej obrazovky."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS ne dopušta aplikacijama izravno otvaranje alata za odabir widgeta. Dodajte ga s početnog zaslona."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS aplikacijam ne dovoli neposrednega odpiranja izbirnika gradnikov. Dodajte ga z začetnega zaslona."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS ei lase rakendustel vidinavalijat otse avada. Lisage see avakuvalt."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS neļauj lietotnēm tieši atvērt logrīku atlasītāju. Pievienojiet to no sākuma ekrāna."
          }
        }
      }
    },
    "It’s for anyone who’s ever wanted to follow through, but found it hard to keep going.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È per chiunque abbia mai voluto portare a termine qualcosa, ma abbia trovato difficile andare avanti."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це для всіх, хто хотів доводити справи до кінця, але кому було важко продовжувати."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es para cualquiera que alguna vez haya querido seguir adelante, pero le haya resultado difícil seguir adelante."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Es para cualquiera que alguna vez haya querido seguir adelante, pero le haya resultado difícil seguir adelante."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "É para quem sempre quis seguir em frente, mas achou difícil continuar."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es richtet sich an alle, die schon immer durchhalten wollten, es aber schwer fanden, weiterzumachen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C’est pour tous ceux qui ont toujours voulu aller jusqu’au bout, mais qui ont eu du mal à continuer."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het is voor iedereen die ooit door wilde gaan, maar het moeilijk vond om door te gaan."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er for alle, der nogensinde har ønsket at følge op, men har haft svært ved at fortsætte."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det är för alla som någonsin velat följa upp, men haft svårt att fortsätta."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er for alle som noen gang har ønsket å følge opp, men har funnet det vanskelig å fortsette."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jest przeznaczony dla każdego, kto kiedykolwiek chciał kontynuować, ale trudno mu było kontynuować."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Se on tarkoitettu kaikille, jotka ovat koskaan halunneet seurata sitä, mutta joiden on ollut vaikea jatkaa."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Je pro každého, kdo to někdy chtěl dotáhnout do konce, ale bylo pro něj těžké pokračovat."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Este pentru oricine și-a dorit vreodată să continue, dar i-a fost greu să continue."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Mindenkinek szól, aki valaha is végig akarta követni, de nehezen tudta folytatni."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Je pre každého, kto to niekedy chcel dotiahnuť do konca, ale bolo pre neho ťažké pokračovať."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Namijenjen je svima koji su ikada željeli nastaviti, ali im je bilo teško nastaviti."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Za vsakogar, ki je kdaj želel slediti, a je bilo težko nadaljevati."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "See on mõeldud kõigile, kes on kunagi tahtnud seda teha, kuid kellel oli raske jätkata."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tas ir paredzēts ikvienam, kurš kādreiz ir vēlējies sekot līdzi, taču viņam bija grūti turpināt."
          }
        }
      }
    },
    "It’s not perfect, and I’m okay with that.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non è perfetto, e per me va bene così."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Він не ідеальний, і це нормально."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No es perfecto y estoy de acuerdo con eso."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "No es perfecto y estoy de acuerdo con eso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não é perfeito e estou bem com isso."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es ist nicht perfekt und ich bin damit einverstanden."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce n’est pas parfait et je suis d’accord avec ça."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het is niet perfect, en daar ben ik oké mee."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er ikke perfekt, og det er jeg okay med."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det är inte perfekt, och jag är okej med det."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er ikke perfekt, og jeg er ok med det."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie jest idealnie i nie przeszkadza mi to."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Se ei ole täydellinen, ja olen ihan okei sen kanssa."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Není to dokonalé a jsem s tím smířený."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu este perfect și sunt de acord cu asta."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez nem tökéletes, és ezzel rendben is vagyok."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie je to dokonalé a ja som s tým v pohode."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nije savršeno i slažem se s tim."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ni popolno in s tem se strinjam."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "See pole täiuslik ja ma olen sellega rahul."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tas nav ideāls, un man tas ir labi."
          }
        }
      }
    },
    "It’s the quiet force that turns small, ordinary actions into extraordinary results over time.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È la forza silenziosa che trasforma piccole azioni ordinarie in risultati straordinari nel tempo."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це тиха сила, яка з часом перетворює маленькі звичайні дії на надзвичайні результати."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es la fuerza silenciosa que convierte acciones pequeñas y ordinarias en resultados extraordinarios con el tiempo."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Es la fuerza silenciosa que convierte acciones pequeñas y ordinarias en resultados extraordinarios con el tiempo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "É a força silenciosa que transforma ações pequenas e comuns em resultados extraordinários ao longo do tempo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es ist die stille Kraft, die kleine, gewöhnliche Handlungen im Laufe der Zeit in außergewöhnliche Ergebnisse verwandelt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "C’est la force tranquille qui transforme de petites actions ordinaires en résultats extraordinaires au fil du temps."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het is de stille kracht die kleine, gewone acties in de loop van de tijd omzet in buitengewone resultaten."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er den stille kraft, der forvandler små, almindelige handlinger til ekstraordinære resultater over tid."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det är den tysta kraften som förvandlar små, vanliga handlingar till extraordinära resultat över tid."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er den stille kraften som gjør små, vanlige handlinger til ekstraordinære resultater over tid."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To cicha siła, która z biegiem czasu zmienia małe, zwyczajne działania w niezwykłe rezultaty."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Se on hiljainen voima, joka muuttaa pienet, tavalliset teot poikkeuksellisiksi tuloksiksi ajan myötä."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Je to tichá síla, která v průběhu času mění malé, obyčejné činy na mimořádné výsledky."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Este forța liniștită care transformă acțiunile mici, obișnuite, în rezultate extraordinare în timp."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez az a csendes erő, amely az apró, hétköznapi cselekedeteket idővel rendkívüli eredményekké változtatja."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Je to tichá sila, ktorá časom premení malé, bežné činy na mimoriadne výsledky."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "To je tiha sila koja male, obične radnje s vremenom pretvara u izvanredne rezultate."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "To je tiha sila, ki majhna, običajna dejanja čez čas spremeni v izjemne rezultate."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "See on vaikne jõud, mis muudab väikesed tavalised tegevused aja jooksul erakordseteks tulemusteks."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tas ir klusais spēks, kas laika gaitā mazas, parastas darbības pārvērš neparastos rezultātos."
          }
        }
      }
    },
