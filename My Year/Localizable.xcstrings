    "Track a simple yes/no each week. Great for goals you either hit or miss across the week.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track a simple yes/no each week. Great for goals you either hit or miss across the week."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledujte jednoduché ano/ne každý týden. Skvělé pro cíle, které jste během týdne dosáhli nebo nestihli."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spor et simpelt ja/nej hver uge. Fantastisk til mål, du enten rammer eller går glip af i løbet af ugen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolgen Sie jede Woche ein einfaches Ja/Nein. Ideal für Ziele, die Sie im Laufe der Woche erreichen oder verfehlen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Realice un seguimiento de un simple sí/no cada semana. Ideal para objetivos que aciertas o fallas a lo largo de la semana."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Realice un seguimiento de un simple sí/no cada semana. Ideal para objetivos que aciertas o fallas a lo largo de la semana."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Jälgige igal nädalal lihtsat jah/ei. Suurepärane väravate jaoks, mille olete nädala jooksul tabanud või tegemata."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Seuraa yksinkertainen kyllä/ei joka viikko. Sopii erinomaisesti maaleihin, joihin joko osut tai jäät paitsi viikon aikana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez un simple oui/non chaque semaine. Idéal pour les objectifs que vous atteignez ou manquez au cours de la semaine."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pratite jednostavno da/ne svaki tjedan. Izvrstan za ciljeve koje postignete ili propustite tijekom tjedna."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kövesse nyomon az egyszerű igent/nemet minden héten. Kiválóan alkalmas a hét folyamán elért vagy kihagyott gólokhoz."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni traccia di un semplice sì/no ogni settimana. Ottimo per gli obiettivi che raggiungi o manchi durante la settimana."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Katru nedēļu izsekojiet vienkāršu jā/nē. Lieliski piemērots vārtu guvumiem, kurus nedēļas laikā trāpījat vai izlaižat."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Spor et enkelt ja/nei hver uke. Flott for mål du enten treffer eller går glipp av i løpet av uken."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd elke week een eenvoudig ja/nee bij. Ideaal voor doelen die je de hele week wel of niet haalt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Śledź proste tak/nie co tydzień. Świetnie nadaje się do celów, które trafiasz lub nie trafiasz w ciągu tygodnia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acompanhe um simples sim/não a cada semana. Ótimo para metas que você acertou ou errou ao longo da semana."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Urmăriți un simplu da/nu în fiecare săptămână. Excelent pentru golurile pe care le atingeți sau le ratați pe parcursul săptămânii."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Sledujte jednoduché áno/nie každý týždeň. Skvelé pre ciele, ktoré počas týždňa dosiahnete alebo nestihnete."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vsak teden sledite preprostemu da/ne. Odlično za cilje, ki jih čez teden dosežete ali zgrešite."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spåra ett enkelt ja/nej varje vecka. Perfekt för mål du antingen träffar eller missar under veckan."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відстежуйте прості так/ні щотижня. Чудово підходить для цілей, які ви досягли або пропустили протягом тижня."
          }
        }
      }
    },
    "Log a numeric value per week, like workouts done or kilometers covered.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log a numeric value per week, like workouts done or kilometers covered."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaznamenejte číselnou hodnotu za týden, jako jsou odcvičené tréninky nebo ujeté kilometry."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Log en numerisk værdi pr. uge, f.eks. udførte træninger eller tilbagelagte kilometer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Protokollieren Sie einen numerischen Wert pro Woche, z. B. absolvierte Trainingseinheiten oder zurückgelegte Kilometer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra un valor numérico por semana, como entrenamientos realizados o kilómetros recorridos."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra un valor numérico por semana, como entrenamientos realizados o kilómetros recorridos."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Logige nädala kohta arvväärtus, nt tehtud treeningud või läbitud kilomeetrid."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjaa viikoittain numeerinen arvo, kuten suoritetut harjoitukset tai ajetut kilometrit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez une valeur numérique par semaine, comme les entraînements effectués ou les kilomètres parcourus."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zabilježite brojčanu vrijednost po tjednu, poput odrađenih treninga ili prijeđenih kilometara."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Egy heti numerikus érték naplózása, például az elvégzett edzések vagy a megtett kilométerek."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra un valore numerico a settimana, come gli allenamenti effettuati o i chilometri percorsi."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Reģistrējiet skaitlisko vērtību nedēļā, piemēram, veiktos treniņus vai nobrauktos kilometrus."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Logg en numerisk verdi per uke, som utførte treningsøkter eller tilbakelagte kilometer."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Registreer een numerieke waarde per week, zoals uitgevoerde trainingen of afgelegde kilometers."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rejestruj tygodniowo wartość liczbową, np. wykonane treningi lub przebyte kilometry."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Registre um valor numérico por semana, como treinos realizados ou quilômetros percorridos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înregistrați o valoare numerică pe săptămână, cum ar fi antrenamentele efectuate sau kilometri parcurși."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaznamenajte si číselnú hodnotu za týždeň, napríklad odcvičené tréningy alebo prejdené kilometre."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beležite številčno vrednost na teden, na primer opravljene vadbe ali pretečene kilometre."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Logga ett numeriskt värde per vecka, som gjorda träningspass eller tillryggalagda kilometer."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Записуйте числове значення за тиждень, як-от виконані тренування або пройдені кілометри."
          }
        }
      }
    },
    "Check in multiple times across the week toward a weekly target.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Check in multiple times across the week toward a weekly target."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přihlaste se několikrát během týdne směrem k týdennímu cíli."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tjek ind flere gange i løbet af ugen mod et ugentligt mål."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Checken Sie mehrmals in der Woche ein, um ein wöchentliches Ziel zu erreichen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Regístrese varias veces durante la semana para alcanzar un objetivo semanal."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Regístrese varias veces durante la semana para alcanzar un objetivo semanal."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Iganädalase eesmärgi saavutamiseks registreeruge nädala jooksul mitu korda."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjaudu sisään useita kertoja viikon aikana kohti viikkotavoitetta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez-vous plusieurs fois au cours de la semaine pour atteindre un objectif hebdomadaire."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prijavite se više puta tijekom tjedna prema tjednom cilju."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Jelentkezzen be többször a héten a heti cél elérése érdekében."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Effettua il check-in più volte durante la settimana per raggiungere un obiettivo settimanale."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Reģistrējieties vairākas reizes nedēļas laikā, lai sasniegtu nedēļas mērķi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sjekk inn flere ganger i løpet av uken mot et ukentlig mål."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Check meerdere keren per week in voor een wekelijks doel."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Melduj się kilka razy w tygodniu, aby osiągnąć tygodniowy cel."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça check-in várias vezes durante a semana em direção a uma meta semanal."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înregistrați-vă de mai multe ori pe parcursul săptămânii către un obiectiv săptămânal."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nahlasujte sa viackrát počas týždňa smerom k týždennému cieľu."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prijavite se večkrat čez teden, da dosežete tedenski cilj."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Checka in flera gånger under veckan mot ett veckomål."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Заходьте кілька разів протягом тижня, щоб досягти тижневої цілі."
          }
        }
      }
    },
