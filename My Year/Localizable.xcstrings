    "Start with something small enough to do even on a hard day." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Začni něčím tak malým, že to zvládneš i v těžký den."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start med noget så småt, at du kan gøre det selv på en hård dag."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beginne mit etwas, das klein genug ist, dass es auch an schweren Tagen geht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start with something small enough to do even on a hard day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empieza con algo tan pequeño que puedas hacerlo incluso en un día difícil."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empieza con algo tan pequeño que puedas hacerlo incluso en un día difícil."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alusta millestki nii väikesest, et saad seda teha ka raskel päeval."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aloita jostain niin pienestä, että se onnistuu vaikeanakin päivänä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisis quelque chose d’assez petit pour le faire même un jour difficile."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kreni s nečim dovoljno malim da možeš odraditi i na težak dan."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kezdj valami olyan kicsivel, amit egy nehéz napon is meg tudsz csinálni."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Parti da qualcosa che puoi fare anche in una giornata difficile."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sāc ar kaut ko tik mazu, ka vari to izdarīt arī grūtā dienā."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Start med noe så lite at du klarer det selv på en tung dag."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Begin met iets dat klein genoeg is om zelfs op een zware dag te doen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wybierz coś tak małego, że zrobisz to nawet w trudny dzień."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha algo pequeno o bastante para fazer até em um dia difícil."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Începe cu ceva destul de mic încât să-l poți face și într-o zi grea."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Začni niečím tak malým, že to zvládneš aj v ťažký deň."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Začni z nečim dovolj majhnim, da zmoreš tudi na težek dan."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Börja med något så litet att du kan göra det även en jobbig dag."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почни з чогось настільки малого, що це реально зробити навіть у важкий день."
