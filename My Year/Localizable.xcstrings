    "Already started elsewhere? Bring your streak here.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai già iniziato altrove? Porta qui la tua serie."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Уже почали деінде? Перенесіть свою серію сюди."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Ya has empezado en otro lugar? Trae tu racha aquí."
