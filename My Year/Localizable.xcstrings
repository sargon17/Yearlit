    "The accent color changes the current-day dot and highlighted progress number.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The accent color changes the current-day dot and highlighted progress number."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il colore accento cambia il punto del giorno corrente e il numero di avanzamento evidenziato."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Колір акценту змінює крапку поточного дня та виділене число прогресу."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El color de acento cambia el punto del día actual y el número de progreso resaltado."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "El color de acento cambia el punto del día actual y el número de progreso resaltado."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A cor de destaque altera o ponto do dia atual e o número de progresso destacado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Akzentfarbe ändert den Punkt des aktuellen Tages und die hervorgehobene Fortschrittszahl."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La couleur d’accent modifie le point du jour actuel et le nombre de progression mis en évidence."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De accentkleur verandert de stip van vandaag en het gemarkeerde voortgangsgetal."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Accentfarven ændrer prikken for dagen i dag og det fremhævede fremskridtstal."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Accentfärgen ändrar dagens punkt och det markerade framstegstalet."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Aksentfargen endrer dagens prikk og det uthevede fremdriftstallet."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kolor akcentu zmienia kropkę bieżącego dnia i wyróżnioną liczbę postępu."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Korostusväri muuttaa nykyisen päivän pisteen ja korostetun edistysluvun."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zvýrazňující barva změní tečku aktuálního dne a zvýrazněné číslo průběhu."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Culoarea de accent schimbă punctul zilei curente și numărul de progres evidențiat."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kiemelőszín módosítja az aktuális nap pontját és a kiemelt előrehaladási számot."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Farba zvýraznenia zmení bodku aktuálneho dňa a zvýraznené číslo pokroku."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Boja naglaska mijenja točku trenutnog dana i istaknuti broj napretka."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Barva poudarka spremeni piko trenutnega dne in poudarjeno številko napredka."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Rõhuvärv muudab tänase päeva punkti ja esiletõstetud edenemisnumbrit."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Akcenta krāsa maina pašreizējās dienas punktu un izcelto progresa skaitli."
          }
        }
      }
    },
    "One honest day at a time": {
