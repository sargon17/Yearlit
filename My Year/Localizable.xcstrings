        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kom terug als je er klaar voor bent. Vandaag werkt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kom tilbage, når du er klar. I dag virker."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kom tillbaka när du är redo. Idag fungerar."
          }
