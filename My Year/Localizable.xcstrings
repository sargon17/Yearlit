    "This will overwrite %@ %@ within a %@-%@ range." : {
      "comment" : "An alert message explaining that applying a new streak will overwrite existing entries. The first argument is the number of days in the streak range. The second argument is whether the streak is daily or weekly.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "cs" : {
          "stringUnit" : {
