    "So if something’s missing, or something could work better, let me know." : {
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Takže pokud něco chybí nebo něco funguje lépe, dejte mi vědět."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Så hvis noget mangler, eller noget kunne fungere bedre, så lad mig det vide."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn also etwas fehlt oder besser funktionieren könnte, sag es mir."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entonces, si falta algo o si algo podría funcionar mejor, házmelo saber."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entonces, si falta algo o si algo podría funcionar mejor, házmelo saber."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nii et kui midagi on puudu või miski võiks paremini toimida, andke mulle teada."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Joten jos jotain puuttuu tai jokin voisi toimia paremmin, ilmoita minulle."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Donc, s’il manque quelque chose ou si quelque chose pourrait mieux fonctionner, faites-le-moi savoir."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zato mi javi ako nešto nedostaje ili bi moglo raditi bolje."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha valami hiányzik, vagy valami működhetne jobban, szólj."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quindi, se manca qualcosa o qualcosa può funzionare meglio, fammelo sapere."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ja kaut kā trūkst vai kaut kas varētu strādāt labāk, pasaki man."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Så hvis noe mangler, eller noe kan fungere bedre, gi meg beskjed."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dus als er iets ontbreekt of als iets beter zou kunnen werken, laat het me dan weten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli więc czegoś brakuje lub coś mogłoby działać lepiej, daj mi znać."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se algo está faltando ou poderia funcionar melhor, me avise."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă lipsește ceva sau ceva poate funcționa mai bine, spune-mi."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Takže ak niečo chýba alebo by niečo mohlo fungovať lepšie, dajte mi vedieť."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Torej, če kaj manjka ali bi lahko kaj bolje delovalo, mi sporočite."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Så om något saknas eller något kan fungera bättre, låt mig veta."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тож якщо чогось бракує або щось можна зробити краще — дай знати."
          }
        }
      }
    },
