    "Weekly calendars only send one reminder on the selected weekday.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Weekly calendars only send one reminder on the selected weekday."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Týdenní kalendáře odesílají pouze jedno připomenutí ve vybraný den v týdnu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ugentlige kalendere sender kun én påmindelse på den valgte ugedag."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wochenkalender senden nur eine Erinnerung am ausgewählten Wochentag."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los calendarios semanales solo envían un recordatorio en el día de la semana seleccionado."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Los calendarios semanales solo envían un recordatorio en el día de la semana seleccionado."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Nädalakalendrid saadavad valitud nädalapäeval ainult ühe meeldetuletuse."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Viikkokalenterit lähettävät vain yhden muistutuksen valittuna viikonpäivänä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les calendriers hebdomadaires n'envoient qu'un seul rappel le jour de la semaine sélectionné."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tjedni kalendari šalju samo jedan podsjetnik na odabrani radni dan."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A heti naptárak csak egy emlékeztetőt küldenek a kiválasztott hétköznapon."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I calendari settimanali inviano solo un promemoria nel giorno della settimana selezionato."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nedēļas kalendāri atlasītajā nedēļas dienā nosūta tikai vienu atgādinājumu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukekalendere sender kun én påminnelse på den valgte ukedagen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weekkalenders sturen slechts één herinnering op de geselecteerde weekdag."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalendarze tygodniowe wysyłają tylko jedno przypomnienie w wybrany dzień tygodnia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os calendários semanais enviam apenas um lembrete no dia da semana selecionado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Calendarele săptămânale trimit un singur memento în ziua selectată."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Týždenné kalendáre odosielajú iba jednu pripomienku vo vybratý deň v týždni."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tedenski koledarji pošljejo le en opomnik na izbran dan v tednu."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Veckokalendrar skickar bara en påminnelse på den valda veckodagen."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Щотижневі календарі надсилають лише одне нагадування у вибраний день тижня."
          }
        }
      }
    },
    "We will send you a reminder when you're about to miss the week.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We will send you a reminder when you're about to miss the week."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zašleme vám připomenutí, když zmeškáte týden."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi sender dig en påmindelse, når du er ved at gå glip af ugen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir senden Ihnen eine Erinnerung, wenn Sie die Woche verpassen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te enviaremos un recordatorio cuando estés a punto de perderte la semana."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Te enviaremos un recordatorio cuando estés a punto de perderte la semana."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Saadame teile meeldetuletuse, kui teil hakkab nädal vahele jääma."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lähetämme sinulle muistutuksen, kun viikko puuttuu."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous vous enverrons un rappel lorsque vous êtes sur le point de manquer la semaine."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Poslat ćemo vam podsjetnik kada budete trebali propustiti tjedan."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Emlékeztetőt küldünk Önnek, ha kihagyja a hetet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ti invieremo un promemoria quando stai per perdere la settimana."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mēs nosūtīsim jums atgādinājumu, kad grasāties izlaist nedēļu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi sender deg en påminnelse når du er i ferd med å gå glipp av uken."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "We sturen je een herinnering als je de week gaat missen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyślemy Ci przypomnienie, jeśli opuścisz tydzień."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Enviaremos um lembrete quando você estiver prestes a perder a semana."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Vă vom trimite un memento când sunteți pe cale să pierdeți săptămâna."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Keď zmeškáte týždeň, pošleme vám pripomenutie."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ko boste zamudili teden, vam bomo poslali opomnik."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vi skickar en påminnelse till dig när du är på väg att missa veckan."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ми надішлемо вам нагадування, коли ви збираєтеся пропустити тиждень."
          }
        }
      }
    },
    "On the last day of the week at 9 PM, if your streak is at risk, we send one extra reminder.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On the last day of the week at 9 PM, if your streak is at risk, we send one extra reminder."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Poslední den v týdnu ve 21:00, pokud je vaše série ohrožena, vám zašleme jedno připomenutí navíc."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "På den sidste dag i ugen kl. 21.00, hvis din streak er i fare, sender vi en ekstra påmindelse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Ihr Streak am letzten Tag der Woche um 21:00 Uhr gefährdet ist, senden wir eine zusätzliche Erinnerung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El último día de la semana a las 9 p.m., si tu racha está en riesgo, te enviamos un recordatorio adicional."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "El último día de la semana a las 9 p.m., si tu racha está en riesgo, te enviamos un recordatorio adicional."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kui teie seeria on ohus, saadame nädala viimasel päeval kell 21.00 ühe lisameeldetuletuse."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Viikon viimeisenä päivänä klo 21.00, jos sarjasi on vaarassa, lähetämme yhden ylimääräisen muistutuksen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le dernier jour de la semaine à 21 heures, si votre séquence est à risque, nous envoyons un rappel supplémentaire."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Posljednjeg dana u tjednu u 21:00, ako je vaš niz ugrožen, šaljemo jedan dodatni podsjetnik."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hét utolsó napján 21:00-kor, ha a sorozatod veszélyben van, küldünk még egy emlékeztetőt."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'ultimo giorno della settimana alle 21:00, se la tua serie di vittorie è a rischio, invieremo un promemoria aggiuntivo."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nedēļas pēdējā dienā plkst. 21:00, ja jūsu sērija ir apdraudēta, mēs nosūtām vienu papildu atgādinājumu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "På den siste dagen i uken kl. 21.00, hvis rekken din er i fare, sender vi én ekstra påminnelse."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Op de laatste dag van de week om 21.00 uur sturen we één extra herinnering als je streak in gevaar komt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "W ostatnim dniu tygodnia o godzinie 21:00, jeśli Twoja passa jest zagrożona, wysyłamy jedno dodatkowe przypomnienie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "No último dia da semana, às 21h, caso sua sequência esteja em risco, enviamos um lembrete extra."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "În ultima zi a săptămânii, la ora 21:00, dacă numărul dvs. este în pericol, vă trimitem un memento suplimentar."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "V posledný deň týždňa o 21:00, ak je vaša séria ohrozená, pošleme vám jednu pripomienku navyše."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadnji dan v tednu ob 21. uri, če je vaš niz ogrožen, pošljemo en dodaten opomnik."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "På veckans sista dag kl. 21.00, om din streak är i riskzonen, skickar vi en extra påminnelse."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "В останній день тижня о 21:00, якщо ваша смуга під загрозою, ми надішлемо одне додаткове нагадування."
          }
        }
      }
    },
    "While the app is open, hides reminders if you've already logged this week.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "While the app is open, hides reminders if you've already logged this week."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Když je aplikace otevřená, skryje připomenutí, pokud jste se již tento týden přihlásili."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Mens appen er åben, skjuler påmindelser, hvis du allerede har logget på i denne uge."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Während die App geöffnet ist, werden Erinnerungen ausgeblendet, wenn Sie sich diese Woche bereits angemeldet haben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mientras la aplicación está abierta, oculta recordatorios si ya iniciaste sesión esta semana."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Mientras la aplicación está abierta, oculta recordatorios si ya iniciaste sesión esta semana."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kui rakendus on avatud, peidab meeldetuletused, kui olete sel nädalal juba sisse loginud."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kun sovellus on auki, piilottaa muistutukset, jos olet jo kirjautunut tällä viikolla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque l'application est ouverte, masque les rappels si vous êtes déjà connecté cette semaine."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dok je aplikacija otvorena, skriva podsjetnike ako ste se već prijavili ovaj tjedan."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Amíg az alkalmazás nyitva van, elrejti az emlékeztetőket, ha ezen a héten már bejelentkezett."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mentre l'app è aperta, nasconde i promemoria se hai già effettuato l'accesso questa settimana."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamēr lietotne ir atvērta, tiek paslēpti atgādinājumi, ja šonedēļ jau esat pieteicies."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Mens appen er åpen, skjuler påminnelser hvis du allerede har logget denne uken."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Terwijl de app geopend is, worden herinneringen verborgen als je deze week al hebt ingelogd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gdy aplikacja jest otwarta, ukrywa przypomnienia, jeśli jesteś już zalogowany w tym tygodniu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Enquanto o aplicativo está aberto, oculta lembretes se você já fez logon esta semana."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "În timp ce aplicația este deschisă, ascunde mementourile dacă v-ați conectat deja în această săptămână."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Keď je aplikácia otvorená, skryje pripomenutia, ak ste sa už tento týždeň prihlásili."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ko je aplikacija odprta, skrije opomnike, če ste se ta teden že prijavili."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Medan appen är öppen döljer påminnelser om du redan har loggat den här veckan."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Коли програма відкрита, приховує нагадування, якщо ви вже входили цього тижня."
          }
        }
      }
    },
