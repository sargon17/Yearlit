    "Nice! %lld in a row. Let's make it %lld!": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Nice! %1$lld in a row. Let's make it %2$lld!"
          }
        },
        "it": {
