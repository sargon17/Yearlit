    "If this helps you keep a promise to yourself, your review helps me keep building it." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud ti Yearlit pomáhá dodržet slib sobě, tvoje recenze mi pomůže pokračovat."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis Yearlit hjælper dig med at holde et løfte til dig selv, hjælper din anmeldelse mig med at bygge videre."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Yearlit dir hilft, ein Versprechen an dich selbst zu halten, hilft mir deine Bewertung, weiterzubauen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If this helps you keep a promise to yourself, your review helps me keep building it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si esto te ayuda a cumplir una promesa contigo, tu reseña me ayuda a seguir construyendo Yearlit."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si esto te ayuda a cumplir una promesa contigo, tu reseña me ayuda a seguir construyendo Yearlit."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kui see aitab sul endale antud lubadust pidada, aitab sinu arvustus mul seda edasi ehitada."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jos tämä auttaa sinua pitämään lupauksen itsellesi, arvostelusi auttaa minua jatkamaan Yearlitin rakentamista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si Yearlit t’aide à tenir une promesse envers toi-même, ton avis m’aide à continuer de le construire."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ako ti ovo pomaže održati obećanje sebi, tvoja recenzija pomaže meni da nastavim graditi Yearlit."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha ez segít megtartani egy magadnak tett ígéretet, az értékelésed segít tovább építenem."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se Yearlit ti aiuta a mantenere una promessa con te stesso, la tua recensione mi aiuta a continuare a costruirlo."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ja tas palīdz tev turēt sev doto solījumu, tava atsauksme palīdz man turpināt būvēt Yearlit."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis Yearlit hjelper deg å holde et løfte til deg selv, hjelper anmeldelsen din meg å bygge videre."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als dit je helpt een belofte aan jezelf te houden, helpt jouw review mij om Yearlit verder te bouwen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli Yearlit pomaga Ci dotrzymać obietnicy danej sobie, Twoja recenzja pomaga mi rozwijać aplikację dalej."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se isso ajuda você a cumprir uma promessa consigo mesmo, sua avaliação me ajuda a continuar criando o app."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă Yearlit te ajută să ții o promisiune față de tine, recenzia ta mă ajută să continui să-l construiesc."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ak ti Yearlit pomáha dodržať sľub sebe samému, tvoja recenzia mi pomôže budovať ho ďalej."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Če ti to pomaga držati obljubo sebi, mi tvoja ocena pomaga, da Yearlit gradim naprej."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om Yearlit hjälper dig hålla ett löfte till dig själv hjälper din recension mig att fortsätta bygga."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Якщо Yearlit допомагає тобі тримати обіцянку собі, твій відгук допоможе мені будувати його далі."
          }
        }
      }
    },
