    "Come back when you’re ready. Today works." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vraťte se, až budete připraveni. Dnes funguje."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kom tilbage, når du er klar. I dag tæller."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Komm zurück, wenn du bereit bist. Heute reicht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vuelve cuando estés listo. Hoy funciona."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vuelve cuando estés listo. Hoy funciona."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tulge tagasi, kui olete valmis. Tänane päev töötab."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tule takaisin, kun olet valmis. Tänään toimii."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revenez quand vous êtes prêt. Aujourd'hui, ça marche."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vrati se kad budeš spreman. I danas vrijedi."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gyere vissza, amikor készen állsz. A mai nap is jó."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Torna quando sei pronto. Oggi funziona."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atgriezies, kad esi gatavs. Šodiena der."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kom tilbake når du er klar. I dag holder."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kom terug als je er klaar voor bent. Vandaag werkt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wróć, kiedy będziesz gotowy. Dzisiaj działa."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volte quando estiver pronto. Hoje já serve."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Revino când ești gata. Azi e o zi bună."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vráťte sa, keď budete pripravení. Dnes funguje."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vrni se, ko boš pripravljen. Tudi danes šteje."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kom tillbaka när du är redo. Idag fungerar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Поверніться, коли будете готові. Сьогодні працює."
          }
        }
      }
    },
