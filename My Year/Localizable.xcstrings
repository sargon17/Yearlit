    "Keep the cue in sight so the habit is hard to miss.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni il segnale in vista, così l'abitudine è difficile da ignorare."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тримай підказку на видноті, щоб звичку було важко пропустити."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenga la señal a la vista para que sea difícil pasar por alto el hábito."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenga la señal a la vista para que sea difícil pasar por alto el hábito."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha a deixa à vista para que seja difícil perder o hábito."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Behalten Sie das Stichwort im Blick, damit die Gewohnheit kaum zu übersehen ist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez le signal en vue pour qu'il soit difficile de rater cette habitude."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd de keu in het zicht, zodat de gewoonte moeilijk te missen is."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold stikordet i syne, så vanen er svær at gå glip af."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Håll köet i sikte så att vanan är svår att missa."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold signalet i sikte slik at vanen er vanskelig å gå glipp av."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Trzymaj wskazówkę w zasięgu wzroku, aby trudno było przeoczyć nawyk."
          }
        }
      }
    },
