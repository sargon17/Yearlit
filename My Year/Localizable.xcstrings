    "Choose the wallpaper in Yearlit. The Shortcut keeps using Create Daily Wallpaper.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the wallpaper in Yearlit. The Shortcut keeps using Create Daily Wallpaper."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli lo sfondo in Yearlit. Il comando rapido continua a usare Crea sfondo giornaliero."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть шпалери в Yearlit. Команда й надалі використовує «Створити щоденні шпалери»."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el fondo en Yearlit. El atajo seguirá usando Crear fondo diario."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el fondo en Yearlit. El atajo seguirá usando Crear fondo diario."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha o papel de parede no Yearlit. O atalho continua usando Criar papel de parede diário."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle das Hintergrundbild in Yearlit. Der Kurzbefehl nutzt weiter „Tägliches Hintergrundbild erstellen“."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisis le fond d’écran dans Yearlit. Le raccourci continue d’utiliser Créer le fond d’écran quotidien."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies de achtergrond in Yearlit. De opdracht blijft Dagelijkse achtergrond maken gebruiken."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg baggrundsbilledet i Yearlit. Genvejen fortsætter med at bruge Opret dagligt baggrundsbillede."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj bakgrunden i Yearlit. Genvägen fortsätter använda Skapa daglig bakgrund."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg bakgrunnen i Yearlit. Snarveien fortsetter å bruke Opprett daglig bakgrunn."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz tapetę w Yearlit. Skrót nadal używa Utwórz codzienną tapetę."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse taustakuva Yearlitissä. Pikakomento käyttää edelleen Luo päivittäinen taustakuva -toimintoa."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte tapetu v Yearlit. Zkratka dál používá Vytvořit denní tapetu."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alege fundalul în Yearlit. Scurtătura folosește în continuare Creează fundal zilnic."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válaszd ki a háttérképet a Yearlitben. A Parancs továbbra is a Napi háttérkép létrehozása műveletet használja."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyber tapetu v Yearlit. Skratka ďalej používa Vytvoriť dennú tapetu."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberi pozadinu u Yearlitu. Prečac i dalje koristi Stvori dnevnu pozadinu."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Izberi ozadje v Yearlitu. Bližnjica še naprej uporablja Ustvari dnevno ozadje."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Vali taustapilt Yearlitis. Otsetee kasutab edasi toimingut Loo päevane taustapilt."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Izvēlies fona attēlu Yearlit. Saīsne turpina izmantot Izveidot dienas fona attēlu."
          }
        }
      }
    },
