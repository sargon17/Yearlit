          "stringUnit": {
            "state": "translated",
            "value": "En rask innsjekking kan hjelpe deg med å holde farten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Szybka rejestracja pomoże Ci utrzymać dynamikę."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nopea sisäänkirjautuminen voi auttaa sinua pitämään vauhtia."
          }
        },
        "cs": {
