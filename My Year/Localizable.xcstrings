    "Your 365 starts from your habit start date. Add past completed days if you already have progress.": {
      "comment": "A description below the date picker, explaining how the \"365\" feature works.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo 365 inizia dalla data di avvio dell'abitudine. Aggiungi i giorni passati completati se hai già progressi."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Твій 365 починається з дати старту звички. Додай минулі завершені дні, якщо вже маєш прогрес."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu 365 empieza en la fecha de inicio de tu hábito. Agrega los días anteriores completados si ya tienes progreso."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu 365 empieza en la fecha de inicio de tu hábito. Agrega los días anteriores completados si ya tienes progreso."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu 365 começa na data de início do hábito. Adicione dias anteriores concluídos se você já tiver progresso."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr 365 beginnt mit dem Startdatum Ihrer Gewohnheit. Fügen Sie vergangene abgeschlossene Tage hinzu, wenn Sie bereits Fortschritte gemacht haben."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre 365 commence à partir de la date de début de votre habitude. Ajoutez les jours passés terminés si vous avez déjà des progrès."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw 365 begint vanaf de startdatum van uw gewoonte. Voeg afgelopen voltooide dagen toe als je al voortgang hebt geboekt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din 365 starter fra din vane startdato. Tilføj tidligere afsluttede dage, hvis du allerede har fremskridt."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din 365 börjar från ditt vana startdatum. Lägg till tidigare avslutade dagar om du redan har framsteg."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Din 365 starter fra din vane startdato. Legg til siste fullførte dager hvis du allerede har fremgang."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje 365 zaczyna się od daty rozpoczęcia Twojego nawyku. Dodaj ukończone dni, jeśli masz już postęp."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "365 alkaa tapasi alkamispäivästä. Lisää menneet täytetyt päivät, jos edistyminen on jo tapahtunut."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše 365 začíná od vašeho obvyklého počátečního data. Přidejte minulé dokončené dny, pokud již máte pokrok."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "365 începe de la data de începere a obiceiului. Adăugați zilele trecute, dacă aveți deja progrese."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A 365-ös szám a szokás kezdő dátumától kezdődik. Adja hozzá az elmúlt teljesített napokat, ha már van előrehaladás."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša 365 sa začína od vášho obvyklého dátumu začiatku. Pridajte minulé dokončené dni, ak už máte pokrok."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaš 365 počinje od datuma početka vaše navike. Dodajte prošle dovršene dane ako već imate napredak."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaš 365 se začne od datuma začetka vaše navade. Dodajte pretekle dopolnjene dni, če že napredujete."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Teie 365 algab teie harjumuse alguskuupäevast. Lisage viimased täidetud päevad, kui teil on juba edusamme."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Jūsu 365 sākas no jūsu ieraduma sākuma datuma. Pievienojiet pēdējās pabeigtās dienas, ja jums jau ir progress."
          }
        }
      }
    },
    "Your days shape your life.": {
