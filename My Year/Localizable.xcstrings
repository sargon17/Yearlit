        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela écrasera %@%@ dans une plage %@-%@."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hierdoor wordt %@%@ binnen een bereik van %@-%@ overschreven."
