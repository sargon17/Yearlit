    "Unarchiving restores this calendar to your boards and tracking lists.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il ripristino riporta questo calendario nelle tue bacheche e negli elenchi di tracciamento."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Розархівування повертає цей календар на дошки та в списки відстеження."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al desarchivarlo se restaura este calendario en sus tableros y listas de seguimiento."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Al desarchivarlo se restaura este calendario en sus tableros y listas de seguimiento."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O desarquivamento restaura este calendário para seus quadros e listas de rastreamento."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch das Aufheben der Archivierung wird dieser Kalender in Ihren Boards und Tracking-Listen wiederhergestellt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le désarchivage restaure ce calendrier dans vos tableaux et listes de suivi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als u de archivering ongedaan maakt, wordt deze agenda teruggezet naar uw borden en volglijsten."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Fjernelse af arkivering gendanner denne kalender til dine tavler og sporingslister."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Avarkivering återställer den här kalendern till dina anslagstavlor och spårningslistor."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Avarkivering gjenoppretter denne kalenderen til tavler og sporingslister."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przywrócenie archiwizacji przywraca ten kalendarz na Twoje tablice i listy śledzenia."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkistoinnin poistaminen palauttaa tämän kalenterin tauluihisi ja seurantaluetteloihisi."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zrušením archivace se tento kalendář obnoví na vaše nástěnky a seznamy sledování."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dezarhivarea restaurează acest calendar în panourile și listele de urmărire."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az archiválás megszüntetése visszaállítja ezt a naptárt a táblákra és a nyomkövetési listákra."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zrušenie archivácie obnoví tento kalendár na vašich nástenkách a zoznamoch sledovania."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Poništavanje arhiviranja vraća ovaj kalendar na vaše ploče i popise za praćenje."
