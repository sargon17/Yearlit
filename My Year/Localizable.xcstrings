        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne le gardez pas pour vous. Le moyen le plus rapide d’améliorer cette application pour vous est de me dire ce que vous pensez."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nemoj zadržati za sebe. Najbrži način da ovu aplikaciju učinim boljom za tebe je da mi kažeš što ti je na umu."
