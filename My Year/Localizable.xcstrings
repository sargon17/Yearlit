    "Upgrade to Premium to add more times.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Passa a Premium per aggiungere altri check-in."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Оновіться до Premium, щоб додати більше часів."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualice a Premium para agregar más veces."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualice a Premium para agregar más veces."
          }
        },
        "pt-BR": {
