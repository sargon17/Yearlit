    "The more visible your habit is, the easier it is to return.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The more visible your habit is, the easier it is to return."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Čím viditelnější je váš zvyk, tím snazší je se vrátit."
          }
        },
