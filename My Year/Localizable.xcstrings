    "Your 365 is available for daily calendars only.": {
      "comment": "A message displayed when a user tries to access their \"Your 365\" share card on a calendar that is not daily.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo 365 è disponibile solo per i calendari giornalieri."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Твій 365 доступний лише для щоденних календарів."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu 365 está disponible solo para calendarios diarios."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu 365 está disponible solo para calendarios diarios."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu 365 está disponível apenas para calendários diários."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihr 365 ist nur für Tageskalender verfügbar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre 365 est disponible uniquement pour les calendriers quotidiens."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw 365 is alleen beschikbaar voor dagelijkse agenda's."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din 365 er kun tilgængelig for daglige kalendere."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din 365 är endast tillgänglig för dagliga kalendrar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Din 365 er kun tilgjengelig for daglige kalendere."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoja 365 jest dostępna tylko w przypadku kalendarzy dziennych."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "365 on saatavilla vain päivittäisiin kalentereihin."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše 365 je k dispozici pouze pro denní kalendáře."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "365 este disponibil numai pentru calendarele zilnice."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A 365 csak napi naptárak esetén érhető el."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše 365 je k dispozícii iba pre denné kalendáre."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaš 365 dostupan je samo za dnevne kalendare."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaš 365 je na voljo samo za dnevne koledarje."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Teie 365 on saadaval ainult igapäevaste kalendrite jaoks."
          }
