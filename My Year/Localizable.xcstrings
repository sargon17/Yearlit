            "value": "Yearlit wciąż się rozwija — podobnie jak ludzie, którzy go używają."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yearlit kasvaa edelleen – aivan kuten ihmiset, jotka käyttävät sitä."
          }
