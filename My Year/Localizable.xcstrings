    " show up every day, even when motivation wasn’t there.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": " presentarti ogni giorno, anche quando la motivazione non c'era."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": " з'являтися щодня, навіть коли мотивації не було."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": " cumplir cada día, incluso cuando no había motivación."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": " cumplir cada día, incluso cuando no había motivación."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": " aparecer todos os dias, mesmo quando a motivação não estava lá."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": " jeden Tag auftauchen, auch wenn die Motivation nicht da war."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": " se présenter tous les jours, même lorsque la motivation n’était pas là."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": " kom elke dag opdagen, zelfs als de motivatie er niet is."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": " dukke op hver dag, også når motivationen ikke var der."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": " dyker upp varje dag, även när motivationen inte var där."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": " dukker opp hver dag, selv når motivasjonen ikke var der."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": " pojawiać się każdego dnia, nawet jeśli nie było motywacji."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": " ilmestyä joka päivä, vaikka motivaatiota ei olisi ollut."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": " objevovat se každý den, i když motivace nebyla přítomna."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": " să apară în fiecare zi, chiar și atunci când motivația nu era acolo."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": " minden nap megjelenjen, még akkor is, ha nem volt motiváció."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": " objavovať sa každý deň, aj keď motivácia neexistuje."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": " pojavljivati ​​se svaki dan, čak i kad nema motivacije."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": " pojavite se vsak dan, tudi ko ni bilo motivacije."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": " ilmuda iga päev, isegi kui motivatsiooni polnud."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": " parādās katru dienu, pat ja nebija motivācijas."
          }
        }
      }
    },
