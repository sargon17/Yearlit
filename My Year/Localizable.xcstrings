    "Reminders are hard and still evolving. Expect small changes, and occasional delays or misses while we tune reliability.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I promemoria sono difficili e ancora in evoluzione. Aspettati piccoli cambiamenti e occasionali ritardi o mancati invii mentre perfezioniamo l'affidabilità."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Нагадування ще в розробці й продовжують вдосконалюватися. Можливі невеликі зміни, а також інколи затримки або пропуски, поки ми налаштовуємо стабільність."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los recordatorios son difíciles y aún están evolucionando. Espere pequeños cambios y retrasos o errores ocasionales mientras ajustamos la confiabilidad."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Los recordatorios son difíciles y aún están evolucionando. Espere pequeños cambios y retrasos o errores ocasionales mientras ajustamos la confiabilidad."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os lembretes são difíceis e ainda estão em evolução. Espere pequenas mudanças e atrasos ou falhas ocasionais enquanto ajustamos a confiabilidade."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erinnerungen sind schwierig und entwickeln sich noch weiter. Während wir die Zuverlässigkeit optimieren, müssen Sie mit kleinen Änderungen und gelegentlichen Verzögerungen oder Ausfällen rechnen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les rappels sont difficiles et continuent d'évoluer. Attendez-vous à de petits changements et à des retards ou des échecs occasionnels pendant que nous ajustons la fiabilité."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Herinneringen zijn moeilijk en evolueren nog steeds. Verwacht kleine veranderingen en incidentele vertragingen of missers terwijl we de betrouwbaarheid afstemmen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Påmindelser er svære og udvikler sig stadig. Forvent små ændringer og lejlighedsvise forsinkelser eller udeblivelser, mens vi justerer pålideligheden."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Påminnelser är svåra och utvecklas fortfarande. Räkna med små förändringar och enstaka förseningar eller missar medan vi justerar tillförlitligheten."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Påminnelser er vanskelige og utvikler seg fortsatt. Forvent små endringer og sporadiske forsinkelser eller glipp mens vi justerer påliteligheten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przypomnienia są trudne i wciąż ewoluują. Spodziewaj się niewielkich zmian i sporadycznych opóźnień lub chybień podczas dostrajania niezawodności."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Muistutukset ovat vaikeita ja kehittyvät edelleen. Odota pieniä muutoksia ja satunnaisia ​​viiveitä tai puutteita, kun säädämme luotettavuutta."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Upomínky jsou těžké a stále se vyvíjejí. Při ladění spolehlivosti očekávejte malé změny a občasné zpoždění nebo vynechání."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Mementourile sunt grele și încă evoluează. Așteptați-vă la mici schimbări și la întârzieri sau rateuri ocazionale în timp ce reglam fiabilitatea."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az emlékeztetők kemények, és még mindig fejlődnek. A megbízhatóság hangolása közben apró változásokra és időnkénti késésekre vagy kihagyásokra számíthatunk."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pripomenutia sú ťažké a stále sa vyvíjajú. Počas ladenia spoľahlivosti počítajte s malými zmenami a občasnými oneskoreniami alebo zmeškaniami."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Podsjetnici su teški i još uvijek se razvijaju. Očekujte male promjene i povremena kašnjenja ili promašaje dok ugađamo pouzdanost."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opomniki so težki in se še razvijajo. Pričakujte majhne spremembe in občasne zamude ali zamude, medtem ko prilagajamo zanesljivost."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Meeldetuletused on rasked ja arenevad endiselt. Usaldusväärsuse häälestamise ajal on oodata väikseid muudatusi ja aeg-ajalt viivitusi või möödalaskmisi."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Atgādinājumi ir grūti un joprojām attīstās. Sagaidāmas nelielas izmaiņas un neregulāras aizkavēšanās vai neveiksmes, kamēr mēs regulējam uzticamību."
          }
        }
      }
    },
