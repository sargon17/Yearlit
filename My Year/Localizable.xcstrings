    "Tap a calendar to unarchive it and bring it back to your boards.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca un calendario per dearchiviarlo e riportarlo nei tuoi board."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Торкнися календаря, щоб розархівувати його та повернути на дошки."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca un calendario para desarchivarlo y devolverlo a tus tableros."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca un calendario para desarchivarlo y devolverlo a tus tableros."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em um calendário para desarquivá-lo e trazê-lo de volta aos seus painéis."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie auf einen Kalender, um ihn aus dem Archiv zu entfernen und ihn wieder auf Ihre Pinnwände zu bringen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur un calendrier pour le désarchiver et le ramener sur vos tableaux."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik op een agenda om deze uit het archief te halen en terug te plaatsen op uw borden."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk på en kalender for at fjerne den fra arkivet og bringe den tilbage til dine tavler."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck på en kalender för att avarkivera den och ta tillbaka den till dina anslagstavlor."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk på en kalender for å fjerne den fra arkivet og ta den tilbake til tavlene dine."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknij kalendarz, aby go rozpakować i przywrócić na swoje tablice."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Napauta kalenteria poistaaksesi sen arkistosta ja tuodaksesi sen takaisin taulullesi."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Klepnutím na kalendář jej zrušte z archivu a přeneste jej zpět na své nástěnky."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Atingeți un calendar pentru a-l dezarhiva și pentru a-l aduce înapoi în panourile dvs."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Koppintson egy naptárra az archiválás megszüntetéséhez, és visszahozza a táblákra."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Klepnutím na kalendár zrušíte jeho archiváciu a vrátite ho späť na svoje nástenky."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodirnite kalendar da biste ga dearhivirali i vratili na svoje ploče."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tapnite koledar, da ga odstranite iz arhiva in vrnete na svoje table."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Puudutage kalendrit, et see arhiivist eemaldada ja oma tahvlitele tagasi tuua."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pieskarieties kalendāram, lai to izņemtu no arhivēšanas un atgrieztu to dēļos."
          }
        }
      }
    },
    "Tap once each day you do your habit.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca una volta al giorno quando fai la tua abitudine."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Торкайся раз щодня, коли виконуєш звичку."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca una vez cada día que hagas tu hábito."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca una vez cada día que hagas tu hábito."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque uma vez por dia para fazer seu hábito."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie einmal jeden Tag, an dem Sie Ihrer Gewohnheit nachgehen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez une fois par jour lorsque vous prenez votre habitude."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik één keer per dag dat u uw gewoonte uitvoert."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk én gang hver dag, du gør din vane."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck en gång varje dag du gör din vana."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk én gang hver dag du gjør din vane."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stuknij raz dziennie, wykonując swój nawyk."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Napauta kerran joka päivä, kun teet tapasi."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Klepněte jednou denně, když děláte svůj zvyk."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Atingeți o dată pe zi în care vă faceți obiceiul."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Koppintson egyszer minden nap, amikor megszokja."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Poklepte raz každý deň, keď robíte svoj zvyk."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodirnite jednom svaki dan kada obavljate svoju naviku."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tapnite enkrat vsak dan, ko opravite svojo navado."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Puudutage üks kord iga päev, kui teete oma harjumust."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pieskarieties vienreiz katru dienu, kad izpildāt savu ieradumu."
          }
        }
      }
    },
