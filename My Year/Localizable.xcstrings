    "Your 365 starts each daily habit from the day you began. Calendar Year shows January to December progress." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tvých 365 počítá každý denní návyk od prvního dne. Kalendářní rok ukazuje pokrok od ledna do prosince."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din 365 starter hver daglig vane den dag, du begyndte. Kalenderår viser fremgang fra januar til december."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein 365 startet jede tägliche Gewohnheit an dem Tag, an dem du begonnen hast. Kalenderjahr zeigt deinen Fortschritt von Januar bis Dezember."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your 365 starts each daily habit from the day you began. Calendar Year shows January to December progress."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu 365 comienza cada hábito diario desde el día en que empezaste. El año calendario muestra el progreso de enero a diciembre."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu 365 comienza cada hábito diario desde el día en que empezaste. El año calendario muestra el progreso de enero a diciembre."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Sinu 365” alustab iga igapäevast harjumust päevast, mil alustasid. Kalendriaasta näitab edenemist jaanuarist detsembrini."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "365 aloittaa jokaisen päivittäisen tottumuksen aloituspäivästä lähtien. Kalenterivuosi näyttää edistymisen tammi-joulukuussa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ton 365 démarre chaque habitude quotidienne le jour où tu as commencé. L’année civile affiche les progrès de janvier à décembre."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tvojih 365 svaku dnevnu naviku počinje od dana kad si krenuo. Kalendarska godina prikazuje napredak od siječnja do prosinca."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Saját 365 minden napi szokást attól a naptól indít, amikor elkezdted. A naptári év januártól decemberig mutatja a haladást."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo 365 fa partire ogni abitudine quotidiana dal giorno in cui hai cominciato. Anno solare mostra i progressi da gennaio a dicembre."
          }
        },
        "lv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your 365 sāk katru ikdienas ieradumu no dienas, kad sāki. Kalendāra gads rāda progresu no janvāra līdz decembrim."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Din 365 starter hver daglige vane fra dagen du begynte. Kalenderår viser fremgang fra januar til desember."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je 365 start elke dagelijkse gewoonte vanaf de dag waarop je ermee begon. Kalenderjaar toont de voortgang van januari tot en met december."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Twoje 365 rozpoczyna każdy codzienny nawyk od dnia, w którym zacząłeś. Rok kalendarzowy pokazuje postęp od stycznia do grudnia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Seu 365 começa cada hábito diário no dia em que você começou. Ano civil mostra o progresso de janeiro a dezembro."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your 365 începe fiecare obicei zilnic din ziua în care ai început. Anul calendaristic arată progresul din ianuarie până în decembrie."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tvojich 365 počíta každý denný zvyk odo dňa, keď si začal. Kalendárny rok ukazuje pokrok od januára do decembra."
          }
        },
        "sl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tvojih 365 začne vsako dnevno navado na dan, ko začneš. Koledarsko leto pokaže napredek od januarja do decembra."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your 365 startar varje daglig vana från dagen du började. Kalenderår visar framsteg från januari till december."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваші 365 починають кожну щоденну звичку з дня, коли ви почали. Календарний рік показує прогрес із січня по грудень."
          }
        }
      }
    },
    "Your 365 starts from your habit start date. Add past completed days if you already have progress." : {
      "comment" : "A description below the date picker, explaining how the \"365\" feature works.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tvých 365 začíná dnem, kdy návyk začal. Pokud už máš pokrok, přidej hotové minulé dny."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
