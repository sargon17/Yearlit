    "See your current habit streak at a glance." : {
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podívejte se na první pohled na své aktuální návyky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se din nuværende vane med et øjeblik."
