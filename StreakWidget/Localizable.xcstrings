        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sehen Sie Ihre aktuelle Gewohnheitssträhne auf einen Blick."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulta tu racha de hábito de un vistazo."
          }
