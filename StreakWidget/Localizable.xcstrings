    "It's never late to start a new streak!": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non è mai troppo tardi per iniziare una nuova serie!"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ніколи не пізно почати нову серію!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Nunca es tarde para empezar una nueva racha!"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Nunca es tarde para empezar una nueva racha!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nunca é tarde para começar uma nova sequência!"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es ist nie spät, eine neue Serie zu beginnen!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il n'est jamais tard pour démarrer une nouvelle séquence!"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het is nooit te laat om aan een nieuwe reeks te beginnen!"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er aldrig for sent at starte en ny streak!"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det är aldrig försent att starta en ny serie!"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er aldri sent å starte en ny serie!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nigdy nie jest za późno, aby rozpocząć nową passę!"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Koskaan ei ole myöhäistä aloittaa uusi sarja!"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nikdy není pozdě začít novou sérii!"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu este niciodată târziu pentru a începe o nouă serie!"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Soha nem késő új sorozatot kezdeni!"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nikdy nie je neskoro začať novú sériu!"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nikada nije kasno započeti novi niz!"
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nikoli ni prepozno začeti nov niz!"
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunagi pole hilja alustada uut seeriat!"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nekad nav par vēlu sākt jaunu sēriju!"
          }
        }
      }
    },
